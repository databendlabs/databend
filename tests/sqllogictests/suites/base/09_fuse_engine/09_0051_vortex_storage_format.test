statement ok
CREATE TABLE t_vortex (
    id INT,
    name STRING NULL,
    city STRING
) STORAGE_FORMAT = 'vortex'

statement ok
INSERT INTO t_vortex VALUES
    (1, 'alice', 'shanghai'),
    (2, NULL, 'beijing'),
    (3, '中文', 'hangzhou'),
    (4, 'emoji🙂🚀', 'newyork'),
    (5, 'combiningé', 'tokyo')

query ITT rowsort
SELECT id, IFNULL(name, '<NULL>'), city FROM t_vortex ORDER BY id
----
1 alice shanghai
2 <NULL> beijing
3 中文 hangzhou
4 emoji🙂🚀 newyork
5 combiningé tokyo

query TI rowsort
SELECT city, id FROM t_vortex WHERE id IN (1, 3, 5) ORDER BY id
----
shanghai 1
hangzhou 3
tokyo 5

