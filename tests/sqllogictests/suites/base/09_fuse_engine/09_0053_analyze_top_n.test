# Active transactions skip append TopN refresh until transaction stats lifecycle is handled.
statement ok
CREATE TABLE t_txn(a int) approx_distinct_columns = '' analyze_top_n_columns = 'a' analyze_top_n_size = 2

statement ok
begin transaction;

statement ok
INSERT INTO t_txn
SELECT if(number < 90, 1, number - 88)::int FROM numbers(100)

statement ok
INSERT INTO t_txn
SELECT 1::int FROM numbers(20)

statement ok
commit;

query B
SELECT snapshot:table_statistics_location::String IS NULL FROM fuse_dump_snapshots('db_09_0053', 't_txn') LIMIT 1
----
1

# String TopN skips oversized values but preserves counted short values.
statement ok
CREATE TABLE t_string(s string) approx_distinct_columns = '' analyze_top_n_columns = 's' analyze_top_n_size = 1

statement ok
INSERT INTO t_string
SELECT if(number < 10, 'ok', repeat('x', 300)) FROM numbers(100)

query I
SELECT count(*) FROM t_string WHERE s = 'ok'
----
10

query T
EXPLAIN SELECT * FROM t_string WHERE s = 'ok'
----
table: default.db_09_0053.t_string<slt:ignore>estimated rows: 10.00

# If every value is skipped, no table stats should be written.
statement ok
TRUNCATE TABLE t_string

statement ok
INSERT INTO t_string
SELECT repeat('x', 300 + (number % 2)::int) FROM numbers(100)

query B
SELECT snapshot:table_statistics_location::String IS NULL FROM fuse_dump_snapshots('db_09_0053', 't_string') LIMIT 1
----
1

