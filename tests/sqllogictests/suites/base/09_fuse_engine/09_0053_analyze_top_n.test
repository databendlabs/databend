# Edge cases that can reuse a single table because each phase starts with TRUNCATE.
statement ok
CREATE TABLE t_edge(a int) approx_distinct_columns = '' analyze_top_n_columns = 'a' analyze_top_n_size = 2

# Empty fresh stats after TRUNCATE + ANALYZE should behave like a cold start.
statement ok
INSERT INTO t_edge
SELECT if(number < 90, 1, number - 88)::int FROM numbers(100)

statement ok
TRUNCATE TABLE t_edge

statement ok
ANALYZE TABLE t_edge

statement ok
INSERT INTO t_edge
SELECT if(number < 90, 1, number - 88)::int FROM numbers(100)

query T
EXPLAIN SELECT * FROM t_edge WHERE a = 1
----
table: default.db_09_0053.t_edge<slt:ignore>estimated rows: 90.00

