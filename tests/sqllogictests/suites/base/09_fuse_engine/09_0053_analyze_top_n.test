# Append path: first append creates table stats, later appends merge TopN.
statement ok
CREATE TABLE t_append(a int) approx_distinct_columns = '' analyze_top_n_columns = 'a' analyze_top_n_size = 2

statement ok
INSERT INTO t_append
SELECT if(number < 60, 1, 2)::int FROM numbers(100)

query I
SELECT count(*) FROM t_append WHERE a = 1
----
60

query T
EXPLAIN SELECT * FROM t_append WHERE a = 1
----
table: default.db_09_0053.t_append<slt:ignore>estimated rows: 60.00

query B
SELECT snapshot:table_statistics_location::String IS NOT NULL FROM fuse_dump_snapshots('db_09_0053', 't_append') LIMIT 1
----
1

statement ok
INSERT INTO t_append
SELECT 1::int FROM numbers(40)

query I
SELECT count(*) FROM t_append WHERE a = 1
----
100

query T
EXPLAIN SELECT * FROM t_append WHERE a = 1
----
table: default.db_09_0053.t_append<slt:ignore>estimated rows: 100.00

query B
SELECT count(DISTINCT snapshot:table_statistics_location::String) = 2
FROM (SELECT snapshot FROM fuse_dump_snapshots('db_09_0053', 't_append') LIMIT 2)
----
1

