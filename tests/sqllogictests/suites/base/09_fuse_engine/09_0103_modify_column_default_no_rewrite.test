# Test suite for ALTER TABLE MODIFY COLUMN when only the default expression
# changes (no type change). The optimization skips physical table rebuild
# for deterministic defaults and updates metadata only.
#
# Sections:
#   1. Deterministic default-only change is metadata-only (no rebuild).
#   2. Snapshot preserves per-version default for time travel reads.
#   3. Non-deterministic default (rand) forces rebuild.
#   4. Non-deterministic default (nextval) forces rebuild.
#   5. Removing a default is metadata-only; new rows fall back to NULL.
#   6. Invalid default expression is rejected at ALTER time.
#   7. Physically-written column value survives a default change.
#   8. Change tracking: reject column changes on non-empty table.
#   9. Change tracking: no-op re-specification is allowed.
#  10. Change tracking: allow changes on empty table.

statement ok
CREATE OR REPLACE DATABASE db_09_0103

statement ok
USE db_09_0103

# Pre-create the change-tracking table used by sections 8-10.
statement ok
CREATE TABLE t_ct(a INT NOT NULL, b INT DEFAULT 10) CHANGE_TRACKING=true

# ------------------------------------------------------------------
# 1. Deterministic default-only change is metadata-only (no rebuild)
#
# ADD COLUMN creates a column that has no physical data in existing
# blocks. Changing its default to another deterministic value should
# remain metadata-only: fuse_column must still show zero rows for
# that column.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_det(a INT NOT NULL) row_per_block=1

statement ok
INSERT INTO t_det VALUES(1)

statement ok
ALTER TABLE t_det ADD COLUMN b INT DEFAULT 10

query I
SELECT count() FROM fuse_column('db_09_0103', 't_det') WHERE column_name = 'b'
----
0

statement ok
ALTER TABLE t_det MODIFY COLUMN b INT DEFAULT 42

query I
SELECT count() FROM fuse_column('db_09_0103', 't_det') WHERE column_name = 'b'
----
0

query II
SELECT a, b FROM t_det
----
1 42

# ------------------------------------------------------------------
# 2. Snapshot preserves per-version default for time travel reads
#
# Each snapshot records its own default expression. After a
# metadata-only default change, older snapshots still carry the
# previous default value.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t(a INT NOT NULL)

statement ok
INSERT INTO t VALUES(1),(2)

statement ok
ALTER TABLE t ADD COLUMN b INT DEFAULT 10

query II
SELECT a,b FROM t ORDER BY a
----
1 10
2 10

statement ok
ALTER TABLE t MODIFY COLUMN b INT DEFAULT 20

query II
SELECT a,b FROM t ORDER BY a
----
1 20
2 20

query T
SELECT snapshot:schema:fields[1]:default_expr FROM fuse_dump_snapshots('db_09_0103', 't') LIMIT 2
----
"20"
"10"

# ------------------------------------------------------------------
# 3. Non-deterministic default (rand) forces rebuild
#
# rand() is not deterministic, so existing blocks must be rewritten
# to materialize stable values. Verified by checking fuse_column
# shows physical data after the ALTER.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_nd(a INT NOT NULL) row_per_block=1

statement ok
INSERT INTO t_nd VALUES(1)

statement ok
ALTER TABLE t_nd ADD COLUMN b FLOAT DEFAULT 1.0

query I
SELECT count() FROM fuse_column('db_09_0103', 't_nd') WHERE column_name = 'b'
----
0

statement ok
ALTER TABLE t_nd MODIFY COLUMN b FLOAT DEFAULT rand()

query B
SELECT count() >= 1 FROM fuse_column('db_09_0103', 't_nd') WHERE column_name = 'b'
----
1

# ------------------------------------------------------------------
# 4. Non-deterministic default (nextval) forces rebuild
#
# nextval is an AsyncFunctionCall, detected via default_value_evaluable()
# rather than is_deterministic(). This tests that separate detection path.
# ------------------------------------------------------------------

statement ok
CREATE SEQUENCE seq_09_0103

statement ok
CREATE TABLE t_nv(a INT NOT NULL) row_per_block=1

statement ok
INSERT INTO t_nv VALUES(1)

statement ok
ALTER TABLE t_nv ADD COLUMN b INT DEFAULT 1

query I
SELECT count() FROM fuse_column('db_09_0103', 't_nv') WHERE column_name = 'b'
----
0

statement ok
ALTER TABLE t_nv MODIFY COLUMN b INT DEFAULT nextval(seq_09_0103)

query B
SELECT count() >= 1 FROM fuse_column('db_09_0103', 't_nv') WHERE column_name = 'b'
----
1

# ------------------------------------------------------------------
# 5. Removing a default is metadata-only; new rows fall back to NULL
#
# MODIFY COLUMN b INT (no DEFAULT clause) removes the default.
# Old rows keep their previous default value (already baked into the
# snapshot). New rows inserted without an explicit value get NULL.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_rm(a INT NOT NULL, b INT DEFAULT 10)

statement ok
INSERT INTO t_rm(a) VALUES(1)

statement ok
ALTER TABLE t_rm MODIFY COLUMN b INT

query II
SELECT a, b FROM t_rm
----
1 10

statement ok
INSERT INTO t_rm(a) VALUES(2)

query IT
SELECT a, b FROM t_rm ORDER BY a
----
1 10
2 NULL

# ------------------------------------------------------------------
# 6. Invalid default expression is rejected at ALTER time
#
# A default that cannot be cast to the column type must fail during
# ALTER, not silently succeed and break later at query time.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_inv(a INT NOT NULL, b INT DEFAULT 0)

statement error
ALTER TABLE t_inv MODIFY COLUMN b INT DEFAULT 'not_a_number'

# ------------------------------------------------------------------
# 7. Physically-written column value survives a default change
#
# When a row was inserted with an explicit column value, that value
# is stored in the data block. Changing the default must not affect
# the physically-written value; only new rows omitting the column
# pick up the new default.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_phys(a INT NOT NULL, b INT DEFAULT 10)

statement ok
INSERT INTO t_phys VALUES(1, 100)

statement ok
ALTER TABLE t_phys MODIFY COLUMN b INT DEFAULT 999

statement ok
INSERT INTO t_phys(a) VALUES(2)

query II
SELECT a, b FROM t_phys ORDER BY a
----
1 100
2 999

# ------------------------------------------------------------------
# 8. Change tracking: reject column changes on non-empty table
#
# Tables with change tracking enabled must not allow metadata-only
# default changes on non-empty tables, because silently altering
# historical row values would break stream/CDC consistency.
# ------------------------------------------------------------------

statement ok
INSERT INTO t_ct(a) VALUES(1)

statement error 1132
ALTER TABLE t_ct MODIFY COLUMN b INT DEFAULT 99

statement ok
INSERT INTO t_ct(a) VALUES(2)

query II
SELECT a,b FROM t_ct ORDER BY a
----
1 10
2 10

statement error 1132
ALTER TABLE t_ct MODIFY COLUMN b STRING

# ------------------------------------------------------------------
# 9. Change tracking: no-op re-specification is allowed
#
# Re-specifying a column with its current type and default is a
# no-op (schema unchanged). It must not be rejected even on a
# non-empty change-tracking table.
# ------------------------------------------------------------------

statement ok
ALTER TABLE t_ct MODIFY COLUMN b INT DEFAULT 10

# ------------------------------------------------------------------
# 10. Change tracking: allow changes on empty table
#
# An empty change-tracking table has no historical rows to corrupt,
# so schema changes are safe.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_ct_empty(a INT NOT NULL, b INT DEFAULT 10) CHANGE_TRACKING=true

statement ok
ALTER TABLE t_ct_empty MODIFY COLUMN b INT DEFAULT 99

query T
SELECT default_expression FROM system.columns WHERE database = 'db_09_0103' AND table = 't_ct_empty' AND name = 'b'
----
99

statement ok
DROP DATABASE db_09_0103