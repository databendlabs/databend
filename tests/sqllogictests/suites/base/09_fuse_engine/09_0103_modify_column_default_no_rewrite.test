# ALTER TABLE MODIFY COLUMN: default-only changes skip physical rebuild.
#
# Sections:
#   1. Deterministic default change skips rebuild.
#   2. Each snapshot preserves its own default for time travel.
#   3. rand() default forces rebuild (is_deterministic check).
#   4. nextval() default forces rebuild (async function check).
#   5. Removing a default is metadata-only.
#   6. Invalid default is rejected at ALTER time.
#   7. Physical column value is not affected by default change.
#   8. Multi-column ALTER rolls back entirely on one bad default.
#   9. Change tracking rejects changes on non-empty table.
#  10. Change tracking allows no-op and empty-table changes.

statement ok
CREATE OR REPLACE DATABASE db_09_0103

statement ok
USE db_09_0103

# ------------------------------------------------------------------
# 1. Deterministic default change skips rebuild
#
# Column added via ADD COLUMN has no physical data. Changing its
# default to another deterministic value stays metadata-only:
# fuse_column still shows zero rows for that column.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_det(a INT NOT NULL) row_per_block=1

statement ok
INSERT INTO t_det VALUES(1)

statement ok
ALTER TABLE t_det ADD COLUMN b INT DEFAULT 10

query I
SELECT count() FROM fuse_column('db_09_0103', 't_det') WHERE column_name = 'b'
----
0

statement ok
ALTER TABLE t_det MODIFY COLUMN b INT DEFAULT 42

query I
SELECT count() FROM fuse_column('db_09_0103', 't_det') WHERE column_name = 'b'
----
0

query II
SELECT a, b FROM t_det
----
1 42

# ------------------------------------------------------------------
# 2. Each snapshot preserves its own default for time travel
#
# After a metadata-only default change, the latest snapshot has the
# new default while older snapshots keep the previous one.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_tt(a INT NOT NULL)

statement ok
INSERT INTO t_tt VALUES(1),(2)

statement ok
ALTER TABLE t_tt ADD COLUMN b INT DEFAULT 10

query II
SELECT a, b FROM t_tt ORDER BY a
----
1 10
2 10

statement ok
ALTER TABLE t_tt MODIFY COLUMN b INT DEFAULT 20

query II
SELECT a, b FROM t_tt ORDER BY a
----
1 20
2 20

query T
SELECT snapshot:schema:fields[1]:default_expr FROM fuse_dump_snapshots('db_09_0103', 't_tt') LIMIT 2
----
"20"
"10"

# ------------------------------------------------------------------
# 3. rand() default forces rebuild (is_deterministic check)
#
# rand() is not deterministic. Existing blocks must be rewritten to
# materialize stable values. fuse_column shows physical data after.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_nd(a INT NOT NULL) row_per_block=1

statement ok
INSERT INTO t_nd VALUES(1)

statement ok
ALTER TABLE t_nd ADD COLUMN b FLOAT DEFAULT 1.0

query I
SELECT count() FROM fuse_column('db_09_0103', 't_nd') WHERE column_name = 'b'
----
0

statement ok
ALTER TABLE t_nd MODIFY COLUMN b FLOAT DEFAULT rand()

query B
SELECT count() >= 1 FROM fuse_column('db_09_0103', 't_nd') WHERE column_name = 'b'
----
1

# ------------------------------------------------------------------
# 4. nextval() default forces rebuild (async function check)
#
# nextval is an async function detected by default_value_evaluable(),
# a separate code path from the is_deterministic() check in #3.
# ------------------------------------------------------------------

statement ok
CREATE SEQUENCE seq_09_0103

statement ok
CREATE TABLE t_nv(a INT NOT NULL) row_per_block=1

statement ok
INSERT INTO t_nv VALUES(1)

statement ok
ALTER TABLE t_nv ADD COLUMN b INT DEFAULT 1

query I
SELECT count() FROM fuse_column('db_09_0103', 't_nv') WHERE column_name = 'b'
----
0

statement ok
ALTER TABLE t_nv MODIFY COLUMN b INT DEFAULT nextval(seq_09_0103)

query B
SELECT count() >= 1 FROM fuse_column('db_09_0103', 't_nv') WHERE column_name = 'b'
----
1

# ------------------------------------------------------------------
# 5. Removing a default is metadata-only
#
# MODIFY COLUMN b INT (no DEFAULT) removes the default. Old rows
# keep their snapshot default. New rows without an explicit value
# get NULL.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_rm(a INT NOT NULL, b INT DEFAULT 10)

statement ok
INSERT INTO t_rm(a) VALUES(1)

statement ok
ALTER TABLE t_rm MODIFY COLUMN b INT

query II
SELECT a, b FROM t_rm
----
1 10

statement ok
INSERT INTO t_rm(a) VALUES(2)

query IT
SELECT a, b FROM t_rm ORDER BY a
----
1 10
2 NULL

# ------------------------------------------------------------------
# 6. Invalid default is rejected at ALTER time
#
# A default that cannot cast to the column type fails immediately.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_inv(a INT NOT NULL, b INT DEFAULT 0)

statement error
ALTER TABLE t_inv MODIFY COLUMN b INT DEFAULT 'not_a_number'

# ------------------------------------------------------------------
# 7. Physical column value is not affected by default change
#
# A row inserted with an explicit value stores it physically.
# Changing the default does not overwrite it. Only new rows
# omitting the column use the new default.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_phys(a INT NOT NULL, b INT DEFAULT 10)

statement ok
INSERT INTO t_phys VALUES(1, 100)

statement ok
ALTER TABLE t_phys MODIFY COLUMN b INT DEFAULT 999

statement ok
INSERT INTO t_phys(a) VALUES(2)

query II
SELECT a, b FROM t_phys ORDER BY a
----
1 100
2 999

# ------------------------------------------------------------------
# 8. Multi-column ALTER rolls back entirely on one bad default
#
# When multiple columns are modified in one ALTER and one has an
# invalid default, the whole statement fails. No types change.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_multi(a INT NOT NULL, b INT NOT NULL)

statement ok
INSERT INTO t_multi VALUES(1, 1)

statement error 1006
ALTER TABLE t_multi MODIFY COLUMN a FLOAT NOT NULL, COLUMN b FLOAT NOT NULL DEFAULT 'a'

query TT
SELECT name, data_type FROM system.columns WHERE database = 'db_09_0103' AND table = 't_multi' ORDER BY name
----
a INT
b INT

# ------------------------------------------------------------------
# 9. Change tracking rejects changes on non-empty table
#
# Metadata-only default changes on non-empty change-tracking tables
# would silently alter historical row values, breaking stream/CDC.
# Both default changes and type changes are rejected.
#
# Exception: re-specifying the same type and default is a no-op
# (schema unchanged) and is allowed.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_ct(a INT NOT NULL, b INT DEFAULT 10) CHANGE_TRACKING=true

statement ok
INSERT INTO t_ct(a) VALUES(1)

# Default change on non-empty CT table — rejected.
statement error 1132
ALTER TABLE t_ct MODIFY COLUMN b INT DEFAULT 99

statement ok
INSERT INTO t_ct(a) VALUES(2)

query II
SELECT a, b FROM t_ct ORDER BY a
----
1 10
2 10

# Type change on non-empty CT table — also rejected.
statement error 1132
ALTER TABLE t_ct MODIFY COLUMN b STRING

# Same type and same default — no-op, allowed.
statement ok
ALTER TABLE t_ct MODIFY COLUMN b INT DEFAULT 10

# ------------------------------------------------------------------
# 10. Change tracking allows changes on empty table
#
# An empty change-tracking table has no rows to corrupt.
# ------------------------------------------------------------------

statement ok
CREATE TABLE t_ct_empty(a INT NOT NULL, b INT DEFAULT 10) CHANGE_TRACKING=true

statement ok
ALTER TABLE t_ct_empty MODIFY COLUMN b INT DEFAULT 99

query T
SELECT default_expression FROM system.columns WHERE database = 'db_09_0103' AND table = 't_ct_empty' AND name = 'b'
----
99

statement ok
DROP DATABASE db_09_0103