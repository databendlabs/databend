# Circular via subquery: sq_v1 -> sq_v2 -> sq_v1 (wrapped in a subquery)
statement error 1029
create or replace view sq_v1 as select * from sq_t where a in (select * from sq_v2);

# Circular via derived table subquery
statement error 1029
create or replace view sq_v1 as select * from (select * from sq_v2) sub;

# Verify views still work after failed attempts
query I
select * from sq_v2;
----
1

