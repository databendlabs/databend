# Test: circular dependency via CREATE OR REPLACE VIEW should fail at DDL time
statement ok
drop view if exists rv_foo2;

statement ok
drop view if exists rv_foo;

statement ok
drop table if exists rv_test;

statement ok
create table rv_test (i int);

statement ok
insert into rv_test values (1);

statement ok
create or replace view rv_foo as (select * from rv_test);

statement ok
create or replace view rv_foo2 as (select * from rv_foo);

# Circular: rv_foo -> rv_foo2 -> rv_foo (via scalar subquery)
statement error 1029
create or replace view rv_foo as (select (select * from rv_foo2));

# Direct self-reference
statement error 1029
create or replace view rv_foo as (select * from rv_foo);

# Circular via EXISTS
statement error 1029
create or replace view rv_foo as (select 1 where exists (select * from rv_foo2));

# Circular via IN subquery
statement error 1029
create or replace view rv_foo as (select * from rv_test where i in (select * from rv_foo2));

# Multi-hop: v1 -> v2 -> v3 -> v1
statement ok
drop view if exists rv_v3;

statement ok
drop view if exists rv_v2;

statement ok
drop view if exists rv_v1;

statement ok
create view rv_v1 as select * from rv_test;

statement ok
create view rv_v2 as select * from rv_v1;

statement ok
create view rv_v3 as select * from rv_v2;

statement error 1029
create or replace view rv_v1 as select * from rv_v3;

# Verify non-circular views still work
query I
select * from rv_v3;
----
1

# Test: circular dependency via ALTER VIEW should also fail
# Reuse rv_v1 -> rv_v2 -> rv_v3 chain

# Direct self-reference via ALTER VIEW
statement error 1029
alter view rv_v1 as select * from rv_v1;

# Circular: rv_v1 -> rv_v3 -> rv_v2 -> rv_v1
statement error 1029
alter view rv_v1 as select * from rv_v3;

# Verify views still work after failed ALTER attempts
query I
select * from rv_v3;
----
1

