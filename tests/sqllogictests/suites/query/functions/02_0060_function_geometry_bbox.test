## Tests for spatial join bbox runtime filter correctness

# -- Spatial join: all pairs filtered by bbox --

statement ok
DROP TABLE IF EXISTS bbox_test_points

statement ok
DROP TABLE IF EXISTS bbox_test_polys

statement ok
CREATE TABLE bbox_test_points (id INT, geom GEOMETRY)

statement ok
CREATE TABLE bbox_test_polys (id INT, geom GEOMETRY)

statement ok
INSERT INTO bbox_test_points VALUES
    (1, TO_GEOMETRY('POINT(100 100)')),
    (2, TO_GEOMETRY('POINT(200 200)'))

statement ok
INSERT INTO bbox_test_polys VALUES
    (1, TO_GEOMETRY('POLYGON((0 0, 1 0, 1 1, 0 1, 0 0))')),
    (2, TO_GEOMETRY('POLYGON((2 2, 3 2, 3 3, 2 3, 2 2))'))

query I
SELECT COUNT(*) FROM bbox_test_points p JOIN bbox_test_polys g ON ST_Within(p.geom, g.geom);
----
0

# -- Spatial join: some pairs pass bbox, some don't --

statement ok
INSERT INTO bbox_test_points VALUES (3, TO_GEOMETRY('POINT(0.5 0.5)'))

query I
SELECT COUNT(*) FROM bbox_test_points p JOIN bbox_test_polys g ON ST_Within(p.geom, g.geom);
----
1

# -- Spatial join with ST_DWithin and distance expansion --

query I
SELECT COUNT(*) FROM bbox_test_points p JOIN bbox_test_polys g ON ST_DWithin(p.geom, g.geom, 0.1);
----
1

query I
SELECT COUNT(*) FROM bbox_test_points p JOIN bbox_test_polys g ON ST_DWithin(p.geom, g.geom, 200.0);
----
4

# -- Spatial join: bbox cache must bind to the geometry used by the spatial predicate --

statement ok
DROP TABLE IF EXISTS bbox_test_multi_probe

statement ok
CREATE TABLE bbox_test_multi_probe (id INT, g1 GEOMETRY, g2 GEOMETRY)

statement ok
INSERT INTO bbox_test_multi_probe VALUES
    (1, TO_GEOMETRY('POINT(100 100)'), TO_GEOMETRY('POINT(0.5 0.5)'))

query I
SELECT COUNT(*)
FROM bbox_test_multi_probe p
JOIN bbox_test_polys g
    ON ST_Within(p.g2, g.geom) AND p.g1 IS NOT NULL;
----
1

# -- Spatial join: predicate arguments can be reversed --

query I
SELECT COUNT(*)
FROM bbox_test_polys g
JOIN bbox_test_points p
    ON ST_Contains(g.geom, p.geom);
----
1

# -- Spatial join: multiple spatial predicates remain conservative --

query I
SELECT COUNT(*)
FROM bbox_test_multi_probe p
JOIN bbox_test_polys g
    ON ST_Within(p.g2, g.geom)
   AND ST_Intersects(p.g2, g.geom);
----
1

# -- Cleanup --

statement ok
DROP TABLE bbox_test_points

statement ok
DROP TABLE bbox_test_polys

statement ok
DROP TABLE bbox_test_multi_probe

# -- Join-level SRID mismatch must still raise error --

statement ok
DROP TABLE IF EXISTS srid_a

statement ok
DROP TABLE IF EXISTS srid_b

statement ok
CREATE TABLE srid_a (geom GEOMETRY)

statement ok
CREATE TABLE srid_b (geom GEOMETRY)

statement ok
INSERT INTO srid_a VALUES (ST_SetSRID(TO_GEOMETRY('POINT(0 0)'), 4326))

statement ok
INSERT INTO srid_b VALUES (ST_SetSRID(TO_GEOMETRY('POINT(100 100)'), 3857))

statement error Incompatible SRID
SELECT * FROM srid_a JOIN srid_b ON ST_Within(srid_a.geom, srid_b.geom)

statement ok
DROP TABLE srid_a

statement ok
DROP TABLE srid_b

# -- Join with NULL geometry: must not crash or drop valid rows --

statement ok
DROP TABLE IF EXISTS null_geom_a

statement ok
DROP TABLE IF EXISTS null_geom_b

statement ok
CREATE TABLE null_geom_a (id INT, geom GEOMETRY NULL)

statement ok
CREATE TABLE null_geom_b (id INT, geom GEOMETRY)

statement ok
INSERT INTO null_geom_a VALUES (1, TO_GEOMETRY('POINT(0.5 0.5)')), (2, NULL)

statement ok
INSERT INTO null_geom_b VALUES (1, TO_GEOMETRY('POLYGON((0 0, 1 0, 1 1, 0 1, 0 0))'))

query I
SELECT a.id FROM null_geom_a a JOIN null_geom_b b ON ST_Within(a.geom, b.geom);
----
1

statement ok
DROP TABLE null_geom_a

statement ok
DROP TABLE null_geom_b
