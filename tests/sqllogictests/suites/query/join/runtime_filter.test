insert into rf_expr_probe_t3 values (3);

query I
select count(*)
from rf_expr_probe_t1 t1
join rf_expr_probe_t2 t2 on t1.a = cast(t2.x + t2.y as bigint)
join rf_expr_probe_t3 t3 on t1.a = t3.a;
----
1

