statement ok
create table rf_expr_probe_t2(x int, y int);

statement ok
create table rf_expr_probe_t3(a bigint);

statement ok
insert into rf_expr_probe_t1 values (3), (5);

statement ok
insert into rf_expr_probe_t2 values (1, 2), (2, 3);

