# Builtin function names should always be case-insensitive,
# regardless of unquoted_ident_case_sensitive setting.
statement ok
set unquoted_ident_case_sensitive = 1

query T
SELECT DATE_FORMAT('2020-01-01', '%Y-%m-%d')
----
2020-01-01

query T
SELECT Upper('hello')
----
HELLO

