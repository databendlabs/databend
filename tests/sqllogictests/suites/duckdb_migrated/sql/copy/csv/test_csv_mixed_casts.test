# Try Decimal

statement error
FROM read_csv(
    '{DATA_DIR}/csv/mixed_decimal.csv',
    auto_detect = false,
    header = true,
    delim = '|',
    decimal_separator = ';',
     columns = {
      'A': 'INTEGER',
      'B': 'DECIMAL',
    },
    ignore_errors = true
);
