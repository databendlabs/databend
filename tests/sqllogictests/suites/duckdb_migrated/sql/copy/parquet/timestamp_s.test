statement ok
create table t (ts TIMESTAMP_S);

# Populate with timestamps 6 minutes apart, just to produce some mock data

statement ok
insert into t select make_timestamp((1706961600 + (360 * i))::BIGINT * 1000000) from range(0, 10000) range(i);

query I
select * from t limit 3;
