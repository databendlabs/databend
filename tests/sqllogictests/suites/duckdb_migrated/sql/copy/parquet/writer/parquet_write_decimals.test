DROP TABLE IF EXISTS decimals

statement ok
CREATE TABLE decimals(
	dec4 DECIMAL(4,1),
	dec9 DECIMAL(9,2),
	dec18 DECIMAL(18,3),
	dec38 DECIMAL(38,4)
);

