# DuckDB writes parquet directly to local file paths and verifies them with parquet_scan(...).
# Databend's documented parquet workflow is stage/external-location based rather than direct local
# file writes plus direct local parquet scans.
# DuckDB docs: https://duckdb.org/docs/stable/data/parquet/overview.html
# Databend docs:
# https://docs.databend.cn/guides/load-data/transform/querying-parquet
# https://docs.databend.cn/guides/load-data/load-semistructured/load-parquet
# https://docs.databend.cn/guides/unload-data/

# codec uncompressed
# TODO: unsupported feature
# statement ok
# COPY (SELECT 42, 'hello') TO '{TEMP_DIR}/UNCOMPRESSED.parquet' (FORMAT 'parquet', CODEC 'UNCOMPRESSED');

# TODO: unsupported feature
# query II
# SELECT * FROM parquet_scan('{TEMP_DIR}/UNCOMPRESSED.parquet');
# ----
# 42	hello

# TODO: unsupported feature
# statement ok
# COPY (FROM "{DATA_DIR}/parquet-testing/userdata1.parquet") TO '{TEMP_DIR}/userdata-UNCOMPRESSED.parquet' (FORMAT 'parquet', CODEC 'UNCOMPRESSED', ROW_GROUP_SIZE 10);

# TODO: unsupported feature
# statement ok
# FROM "{TEMP_DIR}/userdata-UNCOMPRESSED.parquet";

