# codec uncompressed
statement ok
COPY (SELECT 42, 'hello') TO '{TEMP_DIR}/UNCOMPRESSED.parquet' (FORMAT 'parquet', CODEC 'UNCOMPRESSED');

query II
SELECT * FROM parquet_scan('{TEMP_DIR}/UNCOMPRESSED.parquet');
----
42	hello

statement ok
COPY (FROM "{DATA_DIR}/parquet-testing/userdata1.parquet") TO '{TEMP_DIR}/userdata-UNCOMPRESSED.parquet' (FORMAT 'parquet', CODEC 'UNCOMPRESSED', ROW_GROUP_SIZE 10);

statement ok
FROM "{TEMP_DIR}/userdata-UNCOMPRESSED.parquet";


