statement ok
DROP TABLE IF EXISTS partitioned_tbl

statement ok
DROP TABLE IF EXISTS partitioned_tbl2

statement ok
CREATE TABLE partitioned_tbl AS SELECT i % 2 AS partition_key, i AS col1, i // 7 AS col2, (i % 3)::VARCHAR AS col3 FROM range(0, 10000) t(i)

query II
SELECT partition_key, SUM(col1)
FROM partitioned_tbl
GROUP BY partition_key
ORDER BY partition_key
----
0	24995000
1	25000000

# make sure the partitioned aggregate is used
# all of these are identical, i.e. this gets folded into a single count aggregate

# TODO: result differs
# query II
# EXPLAIN SELECT partition_key, SUM(col1)
# FROM partitioned_tbl
# GROUP BY partition_key
# ORDER BY partition_key
# ----
# special result marker

# distinct aggregate

query II
SELECT partition_key, COUNT(DISTINCT col2)
FROM partitioned_tbl
GROUP BY partition_key
ORDER BY partition_key
----
0	1429
1	1429

# grouping sets

query II
SELECT partition_key, SUM(col1)
FROM partitioned_tbl
GROUP BY GROUPING SETS ((), (partition_key))
ORDER BY partition_key NULLS LAST
----
0	24995000
1	25000000
NULL	49995000

# filtered aggregate

