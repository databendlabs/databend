statement ok
CREATE TABLE asof_nulls (
	time TIMESTAMP,
	value FLOAT
);

statement ok
INSERT INTO asof_nulls (time, value) VALUES ('2025-07-15 00:00:00', 42);

statement ok
INSERT INTO asof_nulls (time, value) VALUES ('2025-07-15 01:00:00', null);

