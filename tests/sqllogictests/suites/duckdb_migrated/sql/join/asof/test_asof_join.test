# Invalid ASOF JOIN comparison

statement error
SELECT p.ts, e.value
FROM range(0,10) p(ts) ASOF JOIN events0 e
ON p.ts <> e.begin
ORDER BY p.ts ASC

statement error
SELECT p.ts, e.value
FROM range(0,10) p(ts) ASOF JOIN events0 e
ON p.ts = e.begin
ORDER BY p.ts ASC

statement error
SELECT p.ts, e.value
FROM range(0,10) p(ts) ASOF JOIN events0 e
ON p.ts >= e.begin AND p.ts >= e.value
ORDER BY p.ts ASC
