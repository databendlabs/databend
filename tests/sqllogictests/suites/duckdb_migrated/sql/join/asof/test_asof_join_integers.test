statement ok
DROP TABLE IF EXISTS events0

statement ok
DROP TABLE IF EXISTS probe0

# Join on an integer range
statement ok
CREATE TABLE events0 (begin INTEGER, value INTEGER);

statement ok
INSERT INTO events0 VALUES
	(NULL, -1),
	(1, 0),
	(3, 1),
	(6, 2),
	(8, 3),
	(999999, 9)
;

