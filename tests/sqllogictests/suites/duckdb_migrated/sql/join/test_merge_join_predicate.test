statement ok
DROP TABLE IF EXISTS tleft

statement ok
create table tleft as
	select 
		i as k100,
		date_add(SECOND, i, '2024-01-01'::TIMESTAMP) as b100,
		date_add(SECOND, i + 1, '2024-01-01'::TIMESTAMP) as e100
	from generate_series(0, 9) as tbl(i);

query II
explain
select l.k100 as lid, r.k100 as rid
from tleft l 
left join tleft r 
on l.b100 < r.e100
and l.k100 + r.k100 < 10
order by 1
----
