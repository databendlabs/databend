statement ok
DROP TABLE IF EXISTS a

statement ok
CREATE TABLE a(i INTEGER);

statement ok
INSERT INTO a VALUES (42);

query I
SELECT COUNT(*) FROM a;
----
1

# delete everything

statement ok
DELETE FROM a;

query I
SELECT COUNT(*) FROM a;
----
0

statement ok
INSERT INTO a VALUES (42);

query I
SELECT COUNT(*) FROM a;
----
1

# now test rollback of deletion

statement ok
BEGIN TRANSACTION

statement ok
DELETE FROM a;

query I
SELECT COUNT(*) FROM a;
----
0

statement ok
ROLLBACK

query I
SELECT COUNT(*) FROM a;
----
1
