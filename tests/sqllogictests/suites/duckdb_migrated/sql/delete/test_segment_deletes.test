statement ok
DROP TABLE IF EXISTS a

statement ok
CREATE TABLE a(i INTEGER);

# insert the values [0, 1, 2, .. 1022, 1023] repeatedly
# however, make sure the order that we insert them is 

statement ok
INSERT INTO a SELECT * FROM range(0, 1024, 1);

statement ok
INSERT INTO a SELECT * FROM range(0, 1024, 1);

statement ok
INSERT INTO a SELECT * FROM range(0, 1024, 1);

statement ok
INSERT INTO a SELECT * FROM range(0, 1024, 1);

statement ok
INSERT INTO a SELECT * FROM range(0, 1024, 1);

statement ok
INSERT INTO a SELECT * FROM range(0, 1024, 1);

statement ok
INSERT INTO a SELECT * FROM range(0, 1024, 1);

# verify the count

query I
SELECT COUNT(*) FROM a
----
7168

# we test the values 0, 1, 1022 and 1023
# for every tested value, delete it and then rollback

# value = 0

statement ok
BEGIN TRANSACTION;

statement ok
DELETE FROM a WHERE i=0;

# verify the deleted count

query I
SELECT COUNT(*) FROM a
----
7161

statement ok
ROLLBACK

# verify the initial count

query I
SELECT COUNT(*) FROM a
----
7168

# value = 1

statement ok
BEGIN TRANSACTION;

statement ok
DELETE FROM a WHERE i=1;

# verify the deleted count

query I
SELECT COUNT(*) FROM a
----
7161

statement ok
ROLLBACK

# verify the initial count

query I
SELECT COUNT(*) FROM a
----
7168

# value = 1022

statement ok
BEGIN TRANSACTION;

statement ok
DELETE FROM a WHERE i=1022;

# verify the deleted count

query I
SELECT COUNT(*) FROM a
----
7161

statement ok
ROLLBACK

# verify the initial count

query I
SELECT COUNT(*) FROM a
----
7168

# value = 1023

statement ok
BEGIN TRANSACTION;

statement ok
DELETE FROM a WHERE i=1023;

# verify the deleted count

query I
SELECT COUNT(*) FROM a
----
7161

statement ok
ROLLBACK

# verify the initial count

query I
SELECT COUNT(*) FROM a
----
7168

# now, for every tested value, delete it in a separate connection and verify the count
# con2 -> 0

statement ok
BEGIN TRANSACTION;

statement ok
DELETE FROM a WHERE i=0;

query I
SELECT COUNT(*) FROM a;
----
7161

# con3 -> 1

statement ok
BEGIN TRANSACTION;

statement ok
DELETE FROM a WHERE i=1;

query I
SELECT COUNT(*) FROM a;
----
7154

# con4 -> 1022

statement ok
BEGIN TRANSACTION;

statement ok
DELETE FROM a WHERE i=1022;

query I
SELECT COUNT(*) FROM a;
----
7147

# con5 -> 1023

statement ok
BEGIN TRANSACTION;

statement ok
DELETE FROM a WHERE i=1023;

query I
SELECT COUNT(*) FROM a;
----
7140

# con1 still has the original count

query I
SELECT COUNT(*) FROM a;
----
7140

# until we update the other transactions

statement ok
COMMIT

statement ok
COMMIT

statement ok
COMMIT

statement ok
COMMIT

# now the count is updated

query I
