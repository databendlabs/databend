# for BC reasons VARINT is an alias for BIGNUM

statement error
select '+-0'::BIGNUM

statement error
select '-+0'::BIGNUM

statement error
select '-'::BIGNUM

statement error
select '00-0010'::BIGNUM

statement error
select ''::BIGNUM

statement error
select 'bla'::BIGNUM

statement error
select '1000bla'::BIGNUM

statement error
select '1000.bla'::BIGNUM

statement error
select '1000...'::BIGNUM

statement error
select '1000.0.0'::BIGNUM
