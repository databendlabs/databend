statement ok
DROP VIEW IF EXISTS list_int

statement ok
DROP VIEW IF EXISTS list_str

statement ok
CREATE VIEW list_int AS
SELECT * FROM (VALUES
	([1]),
	([1, 2]),
	([1, NULL]),
	([NULL, 2]),
	([NULL, NULL]),
	([NULL]),
	(NULL)
) tbl(i);

# String lists with NULLs in various positions

statement ok
CREATE VIEW list_str AS
SELECT * FROM (VALUES
	(['duck']),
	(['duck', 'goose']),
	(['duck', NULL]),
	([NULL, 'goose']),
	([NULL, NULL]),
	([NULL]),
	(NULL)
) tbl(i);

