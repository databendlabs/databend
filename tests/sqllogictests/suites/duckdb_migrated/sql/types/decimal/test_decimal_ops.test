# use decimal in subquery

query R
SELECT (SELECT '1.0'::DECIMAL(2,1));
----
1.0

query R
SELECT ROUND(CAST(CAST('-100.3' AS DECIMAL(18, 1)) AS REAL), 1);
----
-100.3
