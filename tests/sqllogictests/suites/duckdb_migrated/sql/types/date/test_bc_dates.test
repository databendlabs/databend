# the BC formatted variant is one off

# YEAR function returns the ISO 8601 year

# the year 0 exists in the ISO-8601 format

query T
SELECT DATE '0000-01-01'
----
0000-01-01

# year 0 does not exist in the gregorian calendar

statement error
