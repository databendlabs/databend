# unterminated escape
query I
SELECT TRY_CAST('\\' AS BLOB)
----
5C

query I
SELECT TRY_CAST('\\x3' AS BLOB)
----
5C7833

# invalid hex escape

query I
SELECT TRY_CAST('\\b12' AS BLOB)
----
5C623132

query I
SELECT TRY_CAST('\\xx2' AS BLOB)
----
5C787832

query I
SELECT TRY_CAST('\\x2x' AS BLOB)
----
5C783278

# unescaped ascii

query I
SELECT TRY_CAST('ü' AS BLOB)
----
C3BC

query I
SELECT TRY_CAST('\x12' AS BLOB)
----
12

