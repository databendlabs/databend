statement ok
DROP TABLE IF EXISTS floats

statement ok
create table floats(f FLOAT, i int);

statement ok
insert into floats values ('inf', 1), ('inf', 7), ('-inf', 3), ('nan', 7), ('nan', 19), ('-inf', 2)

query RI
SELECT f, SUM(i) OVER (PARTITION BY f) FROM floats ORDER BY f
----
-Infinity 5
-Infinity 5
Infinity 8
Infinity 8
NaN 26
NaN 26

query RII
SELECT f, i, SUM(i) OVER (ORDER BY f, i) FROM floats ORDER BY f, i
----
-Infinity 2 2
-Infinity 3 5
Infinity 1 6
Infinity 7 13
NaN 7 20
NaN 19 39

query RII
SELECT f, i, SUM(i) OVER (PARTITION BY f ORDER BY f, i) FROM floats ORDER BY f, i
----
-Infinity 2 2
-Infinity 3 5
Infinity 1 1
Infinity 7 8
NaN 7 7
NaN 19 26

query IRI
SELECT i, f, SUM(i) OVER (ORDER BY i, f) FROM floats ORDER BY i, f
----
1 Infinity 1
2 -Infinity 3
3 -Infinity 6
7 Infinity 13
7 NaN 20
19 NaN 39

