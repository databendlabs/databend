statement ok
DROP TABLE IF EXISTS booleans

statement ok
CREATE TABLE booleans AS SELECT b::BOOLEAN b FROM (VALUES (NULL), (0), (1)) tbl(b)

query I
SELECT b::tinyint FROM booleans
----
NULL
0
1

# round-trip

query B
SELECT b::tinyint::bool FROM booleans
----
NULL
0
1

