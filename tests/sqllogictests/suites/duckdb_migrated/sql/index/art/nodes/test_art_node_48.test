# verify sums

query I
SELECT sum(i) FROM integers WHERE i <= 2
----
3

query I
SELECT sum(i) FROM integers WHERE i > 15
----
90

# delete an element and reinsert it

statement ok
DELETE FROM integers WHERE i=16;

statement ok
INSERT INTO integers VALUES (16);

query I
SELECT sum(i) FROM integers WHERE i <= 2
----
3

query I
SELECT sum(i) FROM integers WHERE i > 15
----
90

