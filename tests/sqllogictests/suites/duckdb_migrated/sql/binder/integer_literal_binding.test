# integer literals out of range for type

query T
SELECT typeof(1::TINYINT + 100);
----
TINYINT UNSIGNED

query T
SELECT typeof(1::TINYINT + 10000);
----
SMALLINT UNSIGNED

# integer literals with decimals

query T
SELECT typeof(1.05 + 1)
----
DECIMAL(3, 2)

query T
SELECT typeof(1 + 1);
----
TINYINT UNSIGNED
