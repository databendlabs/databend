# check column names for simple projections and aliases

query IIII
SELECT a, b, a * 2 AS c, b * (a * 2) AS d FROM test ORDER BY a
----
42	10	84	840
43	100	86	8600

# test nested alias in where clause

query IIII
select i as b, b as c, c as d, d as e from integers where e = 3;
----
3	3	3	3

