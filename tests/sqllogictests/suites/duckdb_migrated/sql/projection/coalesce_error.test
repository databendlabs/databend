statement ok
CREATE TABLE vals AS SELECT * FROM (
	VALUES (1, 'hello'), (NULL, '2'), (3, NULL)
) tbl(a, b)

query I
SELECT COALESCE(a, b::INT) FROM vals
----
1
2
