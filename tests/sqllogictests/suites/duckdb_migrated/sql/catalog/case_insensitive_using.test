# natural join

query IIII
SELECT * FROM a NATURAL JOIN b
----
1 2 1 3

query IIIIII
SELECT * FROM a NATURAL JOIN b NATURAL JOIN c
----
1 2 1 3 1 4

# natural full outer join

query IIII
SELECT * FROM a NATURAL FULL OUTER JOIN b
----
1 2 1 3

query IIIIII
SELECT * FROM a NATURAL FULL OUTER JOIN b NATURAL FULL OUTER JOIN c
----
