statement ok
DROP VIEW IF EXISTS duplicate_column_view

statement ok
DROP TABLE IF EXISTS basic_table_a

statement ok
DROP TABLE IF EXISTS basic_table_b

statement ok
create or replace table basic_table_a as select 42 as column_a;

statement ok
create or replace table basic_table_b as select 37 as column_a;

statement ok
create or replace view duplicate_column_view as (
  from basic_table_a t1
  cross join basic_table_b t2
  select
    t1.*,
    t2.*
);

query II
from duplicate_column_view;
----
42	37

