# This will fill up a segment completely with 1 value

statement ok
INSERT INTO TEST SELECT CASE WHEN i%2=0
    THEN
        ''
    ELSE
        ''
END FROM range(0,2214) tbl(i);

# Now create our FSST table

statement ok
CREATE TABLE TEST2 as SELECT * FROM TEST;
