statement ok
DROP TABLE IF EXISTS response

statement ok
DROP TABLE IF EXISTS user_pq

statement ok
CREATE TABLE response(
	id BIGINT,
	response VARCHAR
);

statement ok
INSERT INTO response VALUES
	(1,'yes'),
	(1,'no'),
	(1,'yes'),
	(2,'no'),
	(2,'no');

statement ok
CREATE TABLE user_pq(
	id BIGINT,
	"name" VARCHAR
);

statement ok
INSERT INTO user_pq VALUES
	(1,'alice'),
	(2,'bob');

query ITI
SELECT id, response, COUNT(DISTINCT id)
FROM user_pq
JOIN response USING (id)
GROUP BY CUBE (id, response)
ORDER BY 1 NULLS LAST, 2 NULLS LAST, 3 NULLS LAST
----
1	no	1
1	yes	1
1	NULL	1
2	no	1
2	NULL	1
NULL	no	2
NULL	yes	1
NULL	NULL	2
