NULL Masters NULL 1
NULL Masters NULL 1
NULL PhD 10 1
NULL PhD NULL 1
NULL NULL 7 2
NULL NULL 7 2
NULL NULL 8 1
NULL NULL 8 3
NULL NULL 10 1
