DROP TABLE IF EXISTS students

statement ok
create table students (course VARCHAR, type VARCHAR);

statement ok
insert into students
		(course, type)
	values
		('CS', 'Bachelor'),
		('CS', 'Bachelor'),
		('CS', 'PhD'),
		('Math', 'Masters'),
		('CS', NULL),
		('CS', NULL),
		('Math', NULL);

query TTI
select course, type, count(*) from students group by course, type order by 1, 2, 3;
----
CS Bachelor 2
CS PhD 1
CS NULL 2
Math Masters 1
Math NULL 1

# multiple grouping sets

# multiple grouping sets
# these are combined as if they are regular GROUP BY expressions
# i.e. the result is just GROUP BY course, type

# If multiple grouping items are specified in a single GROUP BY clause,
# then the final list of grouping sets is the cross product of the individual items.

# combining grouping sets with non-grouping sets

# with multiple grouping sets...

# nested grouping sets
# If one GROUPING SETS clause is nested inside another,
# the effect is the same as if all the elements of the inner clause had been written directly in the outer clause.

query ITT
select count(*), course, type
        from students
        group by grouping sets ((course), (), (type))
        order by 1, 2, 3;
----
1 NULL Masters
1 NULL PhD
2 Math NULL
2 NULL Bachelor
3 NULL NULL
5 CS NULL
7 NULL NULL

query ITT
select count(*), course, type
        from students
        group by grouping sets(course, ()), grouping sets(type)
        order by 1, 2, 3;
----
1 CS PhD
1 Math Masters
1 Math NULL
1 NULL Masters
1 NULL PhD
2 CS Bachelor
2 CS NULL
2 NULL Bachelor
3 NULL NULL

query ITT
select count(*), course, type
        from students
        group by grouping sets(course, ()), type
        order by 1, 2, 3;
----
1 CS PhD
1 Math Masters
1 Math NULL
1 NULL Masters
1 NULL PhD
2 CS Bachelor
2 CS NULL
2 NULL Bachelor
3 NULL NULL

query ITT
select count(*), course, type
        from students
        group by grouping sets((course, type), (type))
        order by 1, 2, 3;
----
1 CS PhD
1 Math Masters
1 Math NULL
1 NULL Masters
1 NULL PhD
2 CS Bachelor
2 CS NULL
2 NULL Bachelor
3 NULL NULL

# references to group ids by index

query ITT
select count(*), course, type
        from students
        group by grouping sets((2, 3), (3))
        order by 1, 2, 3;
----
1 CS PhD
1 Math Masters
1 Math NULL
1 NULL Masters
1 NULL PhD
2 CS Bachelor
2 CS NULL
2 NULL Bachelor
3 NULL NULL

query ITT
select count(*), course AS crs, type AS tp
        from students
        group by grouping sets((crs, tp), (tp))
        order by 1, 2, 3;
----
1 CS PhD
1 Math Masters
1 Math NULL
1 NULL Masters
1 NULL PhD
2 CS Bachelor
2 CS NULL
2 NULL Bachelor
3 NULL NULL

