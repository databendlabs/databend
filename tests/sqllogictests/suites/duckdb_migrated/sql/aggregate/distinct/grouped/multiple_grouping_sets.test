DROP TABLE IF EXISTS students

statement ok
create table students (
	course VARCHAR,
	type VARCHAR,
	value BIGINT
);

statement ok
insert into students
		(course, type, value)
	values
		('CS', 'Bachelor', 20),
		('CS', 'Bachelor', 10),
		('CS', 'PhD', -20),
		('Math', 'Masters', 10),
		('CS', NULL, -15),
		('CS', NULL, 10),
		('Math', NULL, 15);

