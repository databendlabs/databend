# scalar average
query RR
SELECT AVG(3), AVG(NULL)
----
3.0 NULL

query RR
SELECT AVG(3::SMALLINT), AVG(NULL::SMALLINT)
----
3.0 NULL

query RR
SELECT AVG(3::DOUBLE), AVG(NULL::DOUBLE)
----
3.0 NULL

