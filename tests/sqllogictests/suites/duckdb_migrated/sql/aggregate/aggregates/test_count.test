# test counts on a set of values

statement ok
CREATE TABLE test_count_integers(i INTEGER);

statement ok
INSERT INTO test_count_integers VALUES (1), (2), (NULL)

query IIIIII
SELECT COUNT(*), COUNT(1), COUNT(i), COUNT(COALESCE(i, 1)), COUNT(DISTINCT i), COUNT(DISTINCT 1) FROM test_count_integers
----
3 3 2 3 2 1

# ordered aggregates are not supported

# cannot do DISTINCT *

