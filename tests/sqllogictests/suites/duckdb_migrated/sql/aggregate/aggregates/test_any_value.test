# Numerics

statement ok
CREATE TABLE test_any_value_five AS SELECT i::tinyint AS i FROM range(1, 6, 1) t1(i)

query I
SELECT ANY_VALUE(i) FROM test_any_value_five
----
1

query II
SELECT i % 3 AS g, ANY_VALUE(i) FROM test_any_value_five GROUP BY 1 ORDER BY 1
----
0	3
1	1
2	2

statement ok
DROP TABLE test_any_value_five

