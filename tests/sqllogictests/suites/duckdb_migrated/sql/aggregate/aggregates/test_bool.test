create table t (d date)

statement ok
insert into t values (DATE'2021-02-09'-1),(DATE'2021-02-09'+1),(NULL)

query BB
select bool_or(d > '2021-02-09') AS or_result,
       bool_and(d > '2021-02-09') AS and_result
from t;
----
1	0

