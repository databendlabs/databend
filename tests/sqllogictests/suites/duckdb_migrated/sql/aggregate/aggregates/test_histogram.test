----
[{"lower":"'2022-01-02'","upper":"'2022-01-02'","ndv":1,"count":1,"pre_sum":0}]

query IT rowsort
select g,histogram(g) over (partition by g%2)
    from hist_data;
----
1 [{"lower":"1","upper":"1","ndv":1,"count":2,"pre_sum":0},{"lower":"3","upper":"3","ndv":1,"count":1,"pre_sum":2},{"lower":"5","upper":"5","ndv":1,"count":1,"pre_sum":3}]
1 [{"lower":"1","upper":"1","ndv":1,"count":2,"pre_sum":0},{"lower":"3","upper":"3","ndv":1,"count":1,"pre_sum":2},{"lower":"5","upper":"5","ndv":1,"count":1,"pre_sum":3}]
2 [{"lower":"2","upper":"2","ndv":1,"count":3,"pre_sum":0}]
2 [{"lower":"2","upper":"2","ndv":1,"count":3,"pre_sum":0}]
2 [{"lower":"2","upper":"2","ndv":1,"count":3,"pre_sum":0}]
3 [{"lower":"1","upper":"1","ndv":1,"count":2,"pre_sum":0},{"lower":"3","upper":"3","ndv":1,"count":1,"pre_sum":2},{"lower":"5","upper":"5","ndv":1,"count":1,"pre_sum":3}]
5 [{"lower":"1","upper":"1","ndv":1,"count":2,"pre_sum":0},{"lower":"3","upper":"3","ndv":1,"count":1,"pre_sum":2},{"lower":"5","upper":"5","ndv":1,"count":1,"pre_sum":3}]

