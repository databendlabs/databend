DROP TABLE IF EXISTS test_aggregate_types_booleans

statement ok
DROP TABLE IF EXISTS test_aggregate_types_integers

statement ok
DROP TABLE IF EXISTS test_aggregate_types_strings

statement ok
CREATE TABLE test_aggregate_types_strings(s STRING, g INTEGER)

statement ok
INSERT INTO test_aggregate_types_strings VALUES ('hello', 0), ('world', 1), (NULL, 0), ('r', 1)

# simple aggregates only

query IITT
SELECT COUNT(*), COUNT(s), MIN(s), MAX(s) FROM test_aggregate_types_strings
----
4 3 hello world

query IITT
SELECT COUNT(*), COUNT(s), MIN(s), MAX(s) FROM test_aggregate_types_strings WHERE s IS NULL
----
1 0 NULL NULL

# add string agg

query TTTT
SELECT STRING_AGG(s, ' '), STRING_AGG(s, ''), STRING_AGG('', ''), STRING_AGG('hello', ' ') FROM test_aggregate_types_strings
----
hello world r helloworldr (empty) hello hello hello hello

# more complex agg (groups)

query IIITTT
SELECT g, COUNT(*), COUNT(s), MIN(s), MAX(s), STRING_AGG(s, ' ') FROM test_aggregate_types_strings GROUP BY g ORDER BY g
----
0 2 1 hello hello hello
1 2 2 r world world r

# complex agg with distinct and order by and conversion from int to string

# complex agg with with distinct and order by with NULL

# empty group

# unsupported aggregates

statement error
SELECT SUM(s) FROM test_aggregate_types_strings GROUP BY g ORDER BY g

statement error
SELECT AVG(s) FROM test_aggregate_types_strings GROUP BY g ORDER BY g

statement ok
CREATE TABLE test_aggregate_types_booleans(b BOOLEAN, g INTEGER)

statement ok
INSERT INTO test_aggregate_types_booleans VALUES (false, 0), (true, 1), (NULL, 0), (false, 1)

query IIBB
SELECT COUNT(*), COUNT(b), MIN(b), MAX(b) FROM test_aggregate_types_booleans
----
4 3 0 1

query IIBB
SELECT COUNT(*), COUNT(b), MIN(b), MAX(b) FROM test_aggregate_types_booleans WHERE b IS NULL
----
1 0 NULL NULL

query IIIBB
SELECT g, COUNT(*), COUNT(b), MIN(b), MAX(b) FROM test_aggregate_types_booleans GROUP BY g ORDER BY g
----
0 2 1 0 0
1 2 2 0 1

query IIIBB
SELECT g, COUNT(*), COUNT(b), MIN(b), MAX(b) FROM test_aggregate_types_booleans WHERE b IS NULL OR b=true GROUP BY g ORDER BY g
----
0 1 0 NULL NULL
1 1 1 1 1

statement error
SELECT AVG(b) FROM test_aggregate_types_booleans GROUP BY g ORDER BY g

statement ok
CREATE TABLE test_aggregate_types_integers(i INTEGER, g INTEGER)

statement ok
INSERT INTO test_aggregate_types_integers VALUES (12, 0), (22, 1), (NULL, 0), (14, 1)

query IIIII
SELECT COUNT(*), COUNT(i), MIN(i), MAX(i), SUM(i) FROM test_aggregate_types_integers
----
4 3 12 22 48

query IIIII
SELECT COUNT(*), COUNT(i), MIN(i), MAX(i), SUM(i) FROM test_aggregate_types_integers WHERE i IS NULL
----
1 0 NULL NULL NULL

query IIIIII
SELECT g, COUNT(*), COUNT(i), MIN(i), MAX(i), SUM(i) FROM test_aggregate_types_integers GROUP BY g ORDER BY g
----
0 2 1 12 12 12
1 2 2 14 22 36

query IIIIII
SELECT g, COUNT(*), COUNT(i), MIN(i), MAX(i), SUM(i) FROM test_aggregate_types_integers WHERE i IS NULL OR i > 15 GROUP BY g ORDER BY g
----
0 1 0 NULL NULL NULL
1 1 1 22 22 22
