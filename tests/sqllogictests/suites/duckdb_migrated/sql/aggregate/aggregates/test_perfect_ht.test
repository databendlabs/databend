statement ok
CREATE OR REPLACE TABLE test_perfect_ht_timeseries(year INTEGER, val INTEGER);

statement ok
INSERT INTO test_perfect_ht_timeseries VALUES (1996, 10), (1997, 12), (1996, 20), (2001, 30), (NULL, 1), (1996, NULL);

query IIII
SELECT year, SUM(val), COUNT(val), COUNT(*) FROM test_perfect_ht_timeseries GROUP BY year ORDER BY year;
----
1996 30 2 3
1997 12 1 1
2001 30 1 1
NULL 1 1 1

# use aggregates with destructors

query I?T
SELECT year, LIST(val), STRING_AGG(val::VARCHAR, ',') FROM test_perfect_ht_timeseries GROUP BY year ORDER BY year;
----
1996 [10,20] 10,20
1997 [12] 12
2001 [30] 30
NULL [1] 1

# we run these tests with and without compressed materialization to make sure we cover all types

statement ok
