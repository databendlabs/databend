statement ok
DROP TABLE IF EXISTS test_sum_doubles

statement ok
DROP TABLE IF EXISTS test_sum_integers

statement ok
CREATE TABLE test_sum_integers(i INTEGER);

statement ok
INSERT INTO test_sum_integers SELECT * FROM range(0, 1000, 1);

# positive numbers

query I
SELECT SUM(i) FROM test_sum_integers;
----
499500

# negative numbers

statement ok
INSERT INTO test_sum_integers SELECT * FROM range(0, -1000, -1);

query I
SELECT SUM(i) FROM test_sum_integers;
----
0

# more negative numbers

statement ok
INSERT INTO test_sum_integers SELECT * FROM range(0, -1000, -1);

query I
SELECT SUM(i) FROM test_sum_integers;
----
-499500

# now perform sum of a constant

query I
SELECT SUM(1) FROM test_sum_integers;
----
3000

# negative constant

query I
SELECT SUM(-1) FROM test_sum_integers;
----
-3000

# negative constant with a low amount of values

query I
SELECT SUM(-1) FROM test_sum_integers WHERE i=-1;
----
-2

# no values

query I
SELECT SUM(-1) FROM test_sum_integers WHERE i>10000;
----
NULL

# bigint sum

statement ok
CREATE TABLE test_sum_bigints(b BIGINT);

# a bunch of huge values

statement ok
INSERT INTO test_sum_bigints SELECT * FROM range(4611686018427387904, 4611686018427388904, 1);

