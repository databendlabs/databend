DROP TABLE IF EXISTS test_sum_integers

statement ok
CREATE TABLE test_sum_integers(i INTEGER);

statement ok
INSERT INTO test_sum_integers SELECT * FROM range(0, 1000, 1);

# positive numbers

query I
SELECT SUM(i) FROM test_sum_integers;
----
499500

# negative numbers

statement ok
INSERT INTO test_sum_integers SELECT * FROM range(0, -1000, -1);

query I
SELECT SUM(i) FROM test_sum_integers;
----
0

# more negative numbers

statement ok
INSERT INTO test_sum_integers SELECT * FROM range(0, -1000, -1);

query I
SELECT SUM(i) FROM test_sum_integers;
----
-499500

# now perform sum of a constant

query I
SELECT SUM(1) FROM test_sum_integers;
----
3000

# negative constant

query I
SELECT SUM(-1) FROM test_sum_integers;
----
-3000

# negative constant with a low amount of values

query I
SELECT SUM(-1) FROM test_sum_integers WHERE i=-1;
----
-2

# no values

query I
SELECT SUM(-1) FROM test_sum_integers WHERE i>10000;
----
NULL

# bigint sum

statement ok
CREATE TABLE test_sum_bigints(b BIGINT);

# a bunch of huge values

statement ok
INSERT INTO test_sum_bigints SELECT * FROM range(4611686018427387904, 4611686018427388904, 1);

# sum them up

# this is too big for a bigint

statement error
SELECT SUM(b)::BIGINT FROM test_sum_bigints

# SUM(BIGINT): state is hugeint_t, return is HUGEINT -> match -> value type is HUGEINT

# SUM(DOUBLE): state is double, return is DOUBLE -> match -> value type is DOUBLE

# SUM(DECIMAL): state is hugeint_t (INT128), return is DECIMAL(38,3) (INT128) -> match -> value type is DECIMAL(38,3)

# When the return type's physical type does NOT match the state type, the value type falls back to the state's physical logical type

# SUM(BOOL): state is int64_t (INT64), return is HUGEINT (INT128) -> no match -> value type is BIGINT

# SUM(SMALLINT): state is int64_t (INT64), return is HUGEINT (INT128) -> no match -> value type is BIGINT

# SUM(DECIMAL(4,2)): state is int64_t (INT64), return is DECIMAL(38,2) (INT128) -> no match -> value type is BIGINT

#
# Order by
#

statement ok
CREATE TABLE test_sum_doubles(n DOUBLE);

statement ok
INSERT INTO test_sum_doubles (n) VALUES ('9007199254740992'::DOUBLE), (1::DOUBLE), (1::DOUBLE), (0::DOUBLE);

# Correct result when ordered by size

# Error as an ordered aggregate

statement error
SELECT (sum(n) WITHIN GROUP(ORDER BY ABS(n)))::BIGINT FROM test_sum_doubles;
