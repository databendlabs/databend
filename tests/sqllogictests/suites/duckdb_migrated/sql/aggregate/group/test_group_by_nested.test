CREATE VIEW longlists AS
SELECT *
FROM ((VALUES
	(21, [1]),
	(22, [NULL]),
	(23, []),
	(NULL::INTEGER, [13]),
	(32, [NULL])
	)
UNION ALL
	select 24 as i, list(r) as pk from range(0, 2000) tbl(r)
UNION ALL
	select 34 as i, list(r) as pk from range(0, 2000) tbl(r)
) sv(v, k);

