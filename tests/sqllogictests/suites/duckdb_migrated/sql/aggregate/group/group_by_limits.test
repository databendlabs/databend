statement ok
DROP TABLE IF EXISTS t

statement ok
CREATE TABLE t(t_k0 TINYINT);

statement ok
INSERT INTO t VALUES (-128), (127);

query II
SELECT t_k0, COUNT(*) FROM t GROUP BY t_k0 ORDER BY 1;
----
