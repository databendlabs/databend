DROP TABLE test

statement ok
CREATE TABLE test(i INTEGER, j INTEGER)

statement ok
INSERT INTO test VALUES (1, 1), (2, 2)

# Can only append to newest table

statement ok
BEGIN TRANSACTION

# con adds a column to test

statement ok
ALTER TABLE test ADD COLUMN k INTEGER

# con2 cannot append now!

