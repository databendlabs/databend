statement ok
DROP TABLE IF EXISTS tbl

statement ok
CREATE TABLE tbl (id INT);

statement ok
INSERT INTO tbl FROM range(0, 10000);

query I
SELECT COUNT(*) FROM tbl
----
10000

# deletes

statement ok
BEGIN;

query I
DELETE FROM tbl WHERE id%2=0
----
5000

query I
SELECT COUNT(*) FROM tbl
----
5000

query II
SELECT COUNT(*), COUNT(*) + 1 FROM tbl
----
5000 5001

statement ok
COMMIT;

query I
SELECT COUNT(*) FROM tbl
----
5000

# transaction local appends

statement ok
BEGIN;

query I
INSERT INTO tbl FROM range(10000, 15000)
----
5000

query I
SELECT COUNT(*) FROM tbl
----
10000

query I
SELECT COUNT(*) FROM tbl
----
10000

statement ok
COMMIT;

query I
SELECT COUNT(*) FROM tbl
