# start a transaction for both nodes
statement ok
BEGIN TRANSACTION

statement ok
BEGIN TRANSACTION

# create a sequence in node one

# node one can see it

# node two can't see it

statement error
SELECT nextval('seq');

statement ok
COMMIT

# node two still can't see it

statement error
SELECT nextval('seq');

statement ok
COMMIT

# we can now see the sequence in node two

# drop sequence seq in a transaction

statement ok
BEGIN TRANSACTION

# node one can't use it anymore

statement error
SELECT nextval('seq');

# rollback cancels the drop sequence

statement ok
ROLLBACK;

# we can still use it

# now we drop it for real

# we can't use it anymore

statement error
SELECT nextval('seq');

statement error
SELECT nextval('seq');
