query R
SELECT epoch(TIMESTAMP '1970-01-01 14:21:13')
----
51673.0

query R
SELECT EXTRACT(epoch FROM TIMESTAMP '1970-01-01 14:21:13')
----
51673.0

query I
SELECT EXTRACT(second FROM TIMESTAMP '1970-01-01 14:21:13')
----
13

query RR
SELECT epoch(TIMESTAMP '1970-01-01 14:21:13.250'), date_part(EPOCH, TIMESTAMP '1970-01-01 14:21:13.250')
----
51673.25 51673.25

query R
