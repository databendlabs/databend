query I
SELECT EXTRACT(hour FROM TIMESTAMP '1970-01-01 00:01:20')
----
0

query I
SELECT EXTRACT(minute FROM TIMESTAMP '1970-01-01 20:08:10.998')
----
8

query I
SELECT EXTRACT(second FROM TIMESTAMP '1970-01-01 20:08:10.330')
----
10

query R
SELECT EXTRACT(epoch FROM TIMESTAMP '1970-01-01 20:08:10.998')
----
72490.998

query II
SELECT EXTRACT(hour FROM TIMESTAMP '1970-01-01 20:08:10.998'), date_part(HOUR, TIMESTAMP '1970-01-01 20:08:10.998')
----
20 20

query II
SELECT EXTRACT(minute FROM TIMESTAMP '1970-01-01 20:08:10.998'), date_part(MINUTE, TIMESTAMP '1970-01-01 20:08:10.998')
----
8 8

query II
SELECT EXTRACT(second FROM TIMESTAMP '1970-01-01 20:08:10.001'), date_part(SECOND, TIMESTAMP '1970-01-01 20:08:10.001')
----
10 10

query RR
SELECT EXTRACT(epoch FROM TIMESTAMP '1970-01-01 20:08:10.001'), date_part(EPOCH, TIMESTAMP '1970-01-01 20:08:10.001')
----
72490.001 72490.001

