CREATE TABLE lineitem (
    l_orderkey INT,
    l_suppkey INT,
    l_partkey INT,
    l_comment VARCHAR,
    l_extendedprice FLOAT,
    l_discount FLOAT,
    l_quantity FLOAT,
    l_tax FLOAT,
    l_returnflag VARCHAR,
    l_linestatus VARCHAR,
    l_shipdate DATE
);

