query T
SELECT 'aaa\x80'::BLOB || 'aaa\x80'::BLOB
----
aaa聙aaa聙

query T
SELECT typeof('aaa\x80'::BLOB || 'aaa\x80'::BLOB)
----
VARCHAR

# concat function works - but it converts to varchar

query T
SELECT concat('aaa\x80'::BLOB, 'aaa\x80'::BLOB)
----
aaa聙aaa聙

query T
SELECT typeof(concat('aaa\x80'::BLOB, 'aaa\x80'::BLOB))
----
VARCHAR
