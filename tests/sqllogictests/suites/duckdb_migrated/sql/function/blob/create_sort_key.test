# test varchar types

statement ok
CREATE TABLE varchars(v VARCHAR);

statement ok
INSERT INTO varchars VALUES ('hello'), ('hello' || chr(0) || chr(0)), ('world'), (''), (NULL)

# test list types

statement ok
CREATE TABLE int_list(l ARRAY(INT));

statement ok
INSERT INTO int_list VALUES ([1, 2, 3]), ([]), ([1]), ([2]), ([NULL]), (NULL);

# test struct types

statement ok
CREATE TABLE structs(s TUPLE(i INT, v VARCHAR));

statement ok
INSERT INTO structs VALUES ((42, 'hello')), ((42, 'hello' || chr(0))), ((43, '')), (NULL), ((42, NULL)), ((NULL, ''))

# test struct types

statement ok
CREATE TABLE list_of_structs(s ARRAY(TUPLE(i INT, v VARCHAR)));

statement ok
INSERT INTO list_of_structs VALUES
([(42, 'hello')]),
([]),
([(42, 'hello'), (84, '')]),
([(43, '')]),
(NULL),
([NULL]),
([(42, NULL)]),
([(NULL, '')]),
([(42, 'hello'), (84, chr(0))]),
([(42, 'hello'), NULL, (84, '')])

# test nested lists

statement ok
CREATE TABLE nested_lists(s ARRAY(ARRAY(INT)));

statement ok
INSERT INTO nested_lists VALUES
([]),
([[], []]),
(NULL),
([NULL]),
([[NULL]]),
([[42, 84]]),
([[42], [84]]),
([[42], NULL, [84]]),
([[42], [NULL], [84]]),
([[1, 2, 3, 4, 5, 6, 7, 8, 9]])

