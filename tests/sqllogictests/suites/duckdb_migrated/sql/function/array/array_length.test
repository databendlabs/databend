# Array length with dimension argument

query I
SELECT array_length(array_value(array_value(1, 2, 2), array_value(3, 4, 3)), 1);
----
2

query I
SELECT array_length(array_value(array_value(1, 2, 2), array_value(3, 4, 3)), 2);
----
3

