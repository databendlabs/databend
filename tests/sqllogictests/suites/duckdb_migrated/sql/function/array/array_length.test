statement ok
DROP TABLE IF EXISTS arrays

# Array length
query I
SELECT length([1, 2, 3]);
----
3

# array length for NULL values

statement ok
create table arrays(a ARRAY(INT));

statement ok
insert into arrays values ([1, 2, 3]), ([4, 5, 6])

query I
select length(a) from arrays;
----
3
3

query I
select length(CAST(NULL AS ARRAY(INT))) from arrays;
----
NULL
NULL

statement ok
insert into arrays values (NULL);

query I
select length(a) from arrays;
----
3
3
NULL

