query I
SELECT date_part(YEAR, INTERVAL '2 years')
----
2

query I
SELECT date_part(DAY, INTERVAL '42 days')
----
42

query I
SELECT date_part(MINUTE, INTERVAL '2066343400 microseconds')
----
34

query R
SELECT date_part(SECOND, INTERVAL '2066343400 microseconds')
----
26.3434

query R
SELECT date_part(EPOCH, INTERVAL '2066343400 microseconds')
----
2066.3434

query I
SELECT year(CAST('2 years' AS INTERVAL))
----
2

query I
SELECT month(CAST('16 months' AS INTERVAL))
----
4

query I
SELECT day(CAST('42 days' AS INTERVAL))
----
42

query R
SELECT epoch(CAST('2066343400 microseconds' AS INTERVAL))
----
2066.3434

query I
SELECT date_part(YEAR, NULL::INTERVAL)
----
NULL

statement ok
DROP TABLE IF EXISTS intervals

statement ok
CREATE TABLE intervals(i INTERVAL, s VARCHAR)

statement ok
INSERT INTO intervals VALUES ('2 years', 'year'), ('16 months', 'quarter'), ('42 days', 'day'), ('2066343400 microseconds', 'minute')

