query I
SELECT date_part(YEAR, INTERVAL '2 years')
----
2

query I
SELECT date_part(DAY, INTERVAL '42 days')
----
42

query I
SELECT date_part(MINUTE, INTERVAL '2066343400 microseconds')
----
34

query R
SELECT date_part(SECOND, INTERVAL '2066343400 microseconds')
----
26.3434

query R
SELECT date_part(EPOCH, INTERVAL '2066343400 microseconds')
----
2066.3434

query I
SELECT year(CAST('2 years' AS INTERVAL))
----
2

query I
SELECT month(CAST('16 months' AS INTERVAL))
----
4

query I
SELECT day(CAST('42 days' AS INTERVAL))
----
42

query R
SELECT epoch(CAST('2066343400 microseconds' AS INTERVAL))
----
2066.3434

query I
SELECT date_part(YEAR, NULL::INTERVAL)
----
NULL

statement ok
DROP TABLE IF EXISTS intervals

statement ok
CREATE TABLE intervals(i INTERVAL, s VARCHAR)

statement ok
INSERT INTO intervals VALUES ('2 years', 'year'), ('16 months', 'quarter'), ('42 days', 'day'), ('2066343400 microseconds', 'minute')

query I
SELECT CAST(NULL AS BIGINT) FROM intervals
----
NULL
NULL
NULL
NULL

query I
SELECT CAST(NULL AS BIGINT) FROM intervals
----
NULL
NULL
NULL
NULL

query I
SELECT CAST(NULL AS BIGINT) FROM intervals
----
NULL
NULL
NULL
NULL

query I
SELECT CASE
    WHEN s = 'year' THEN date_part(YEAR, CAST('4 years 5 months 18 days 128 seconds' AS INTERVAL))
    WHEN s = 'quarter' THEN CAST(((month(CAST('4 years 5 months 18 days 128 seconds' AS INTERVAL)) - 1) / 3) + 1 AS BIGINT)
    WHEN s = 'day' THEN date_part(DAY, CAST('4 years 5 months 18 days 128 seconds' AS INTERVAL))
    WHEN s = 'minute' THEN date_part(MINUTE, CAST('4 years 5 months 18 days 128 seconds' AS INTERVAL))
END FROM intervals
----
4
2
18
2

query I
SELECT CAST(to_second(i) AS BIGINT) FROM intervals
----
0
0
0
26

query R
SELECT date_part(EPOCH, i) FROM intervals
----
62208000.0
41472000.0
3628800.0
2066.3434

query I
SELECT CASE
    WHEN s = 'year' THEN year(i)
    WHEN s = 'quarter' THEN CAST(((month(i) - 1) / 3) + 1 AS BIGINT)
    WHEN s = 'day' THEN day(i)
    WHEN s = 'minute' THEN to_minute(i)
END FROM intervals
----
2
2
42
34

query III
SELECT i, DATE_PART('year', i) AS p, year(i) AS f
FROM intervals
WHERE p <> f;
----

query III
SELECT i, DATE_PART('day', i) AS p, day(i) AS f
FROM intervals
WHERE p <> f;
----

query III
SELECT i, DATE_PART('minute', i) AS p, to_minute(i) AS f
FROM intervals
WHERE p <> f;
----

query ?RR
SELECT i, DATE_PART('second', i) AS p, to_second(i) AS f
FROM intervals
WHERE p <> f;
----

query ?RR
SELECT i, DATE_PART('epoch', i) AS p, epoch(i) AS f
FROM intervals
WHERE p <> f;
----

