DROP TABLE IF EXISTS dates

statement ok
CREATE TABLE dates(d DATE);

# test stats propagation from empty table

query I
SELECT EXTRACT(year FROM d) FROM dates;
----

query I
SELECT EXTRACT(month FROM d) FROM dates;
----

query I
SELECT EXTRACT(day FROM d) FROM dates;
----

query I
SELECT CAST(floor(YEAR(d) / 10) AS INT) FROM dates;
----

query I
SELECT CAST(floor((YEAR(d) - 1) / 100) + 1 AS INT) FROM dates;
----

query I
SELECT CAST(floor((YEAR(d) - 1) / 1000) + 1 AS INT) FROM dates;
----

query I
SELECT CASE WHEN d IS NULL THEN NULL ELSE 0 END FROM dates;
----

