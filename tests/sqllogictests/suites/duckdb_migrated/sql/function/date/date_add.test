# date_add, bigquery

query I
SELECT DATE_ADD(day, 5, DATE '2008-12-25') AS five_days_later;
----
2008-12-30

query I
SELECT DATE_ADD(day, 5, TIMESTAMP '2008-12-25 00:00:00') AS five_days_later;
----
2008-12-30 00:00:00.000000
