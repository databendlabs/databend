# Infinities
#

# PG to_char returns NULL here
# but we can do better.

# PG to_char returns NULL here
# but we can do better.

# non-constant format not supported

statement error
SELECT strftime(DATE '1992-01-01', '%');

statement error
SELECT strptime('-1', '%g');

statement error
SELECT strptime('1000', '%g');

statement error
SELECT strftime('%Y', '1992-01-01');
