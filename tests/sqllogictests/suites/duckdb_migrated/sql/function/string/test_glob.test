statement ok
CREATE TABLE strings(s STRING, pat STRING)

statement ok
INSERT INTO strings VALUES ('abab', 'ab*'), ('aaa', 'a?a'), ('aaa', '*b*')

query T
SELECT s FROM strings WHERE glob(s, 'ab*')
----
abab

query T
SELECT s FROM strings WHERE glob('aba', pat)
----
abab
aaa
aaa

query T
SELECT s FROM strings WHERE glob(s, pat)
----
abab
aaa
