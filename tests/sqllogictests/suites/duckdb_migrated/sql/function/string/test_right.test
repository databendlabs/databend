query TTTTT
SELECT RIGHT('🦆ab', 0), RIGHT('🦆ab', 1), RIGHT('🦆ab', 2), RIGHT('🦆ab', 3), RIGHT('🦆ab', 4)
----
(empty)	b	ab	🦆ab	🦆ab

query TTTTT
SELECT
    RIGHT('abcd', 0),
    SUBSTRING('abc' FROM 2),
    SUBSTRING('abc' FROM 3),
    SUBSTRING('abc' FROM 4),
    SUBSTRING('abc' FROM 5)
----
(empty)	bc	c	(empty)	(empty)

query TTTTT
SELECT
    RIGHT('🦆ab', 0),
    SUBSTRING('🦆ab' FROM 2),
    SUBSTRING('🦆ab' FROM 3),
    SUBSTRING('🦆ab' FROM 4),
    SUBSTRING('🦆ab' FROM 5)
----
(empty)	ab	b	(empty)	(empty)

query TT
SELECT RIGHT('abcdef', 99), RIGHT('🦆ab', 99)
----
abcdef	🦆ab

query TTT
SELECT RIGHT(NULL, 0), RIGHT('abc', NULL), RIGHT(NULL, NULL)
----
NULL	NULL	NULL

query TTT
SELECT RIGHT(NULL, 0), RIGHT('🦆ab', NULL), RIGHT(NULL, NULL)
----
NULL	NULL	NULL

