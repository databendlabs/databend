# empty contains

query III
select CAST(POSITION('' IN 'hello') > 0 AS INT), CAST(POSITION('' IN '') > 0 AS INT), CAST(POSITION('' IN NULL) > 0 AS INT)
----
1	1	NULL

statement ok
CREATE TABLE strings(s VARCHAR, off INTEGER, length INTEGER);

statement ok
INSERT INTO strings VALUES ('hello', 1, 2), ('world', 2, 3), ('b', 1, 1), (NULL, 2, 2)

