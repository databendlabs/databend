statement ok
CREATE TABLE strings(s VARCHAR, t VARCHAR)

statement ok
INSERT INTO strings VALUES ('hello', 'hallo'), ('aloha', 'fello'), ('fellow', 'ducks'), (NULL, NULL)

query T
SELECT concat(CASE
    WHEN s IS NULL OR t IS NULL THEN NULL
    ELSE round(
        array_length(array_intersection(array_distinct(regexp_extract_all(s, '.')), array_distinct(regexp_extract_all(t, '.'))))
        / array_length(array_distinct(array_concat(array_distinct(regexp_extract_all(s, '.')), array_distinct(regexp_extract_all(t, '.'))))),
        1
    )
END, '')
FROM strings
----
