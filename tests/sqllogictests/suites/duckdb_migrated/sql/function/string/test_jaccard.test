statement ok
DROP TABLE IF EXISTS strings

# Databend rewrite: exact Jaccard similarity over distinct character sets.

query T
SELECT concat(round(
    array_length(array_intersection(array_distinct(regexp_extract_all('hello', '.')), array_distinct(regexp_extract_all('hello', '.'))))
    / array_length(array_distinct(array_concat(array_distinct(regexp_extract_all('hello', '.')), array_distinct(regexp_extract_all('hello', '.'))))),
    3
), '')
----
1

query T
SELECT concat(CASE
    WHEN 'hello' IS NULL OR NULL IS NULL THEN NULL
    ELSE round(
        array_length(array_intersection(array_distinct(regexp_extract_all('hello', '.')), array_distinct(regexp_extract_all(NULL, '.'))))
        / array_length(array_distinct(array_concat(array_distinct(regexp_extract_all('hello', '.')), array_distinct(regexp_extract_all(NULL, '.'))))),
        3
    )
END, '')
----
NULL

