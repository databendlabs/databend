statement ok
CREATE TABLE strings(s VARCHAR)

statement ok
INSERT INTO strings VALUES ('here'), ('heres'), ('there'), ('three'), ('threes')

query T
SELECT concat(round(jaro_winkler(s, 'theres'), 2), '')
FROM strings
ORDER BY s
----
0.89
0.94
0.97
0.9
0.96

query T
SELECT concat(round(jaro_winkler('herse', s), 2), '')
FROM strings
ORDER BY s
----
0.95
0.95
0.87
0.73
0.81

query T
SELECT jaro_winkler(NULL, s)
FROM strings
ORDER BY s
----
NULL
NULL
NULL
