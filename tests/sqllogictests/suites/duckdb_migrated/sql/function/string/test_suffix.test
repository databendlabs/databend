----
1

query I
SELECT CAST(RIGHT('two ñ three ₡ four 🦆 end', CHAR_LENGTH('three ₡ four 🦆 end')) = 'three ₡ four 🦆 end' AS INT)
----
1

query I
SELECT CAST(RIGHT('two ñ three ₡ four 🦆 end', CHAR_LENGTH('two ñ three ₡ four 🦆 end')) = 'two ñ three ₡ four 🦆 end' AS INT)
----
1

query I
SELECT CAST(RIGHT('two ñ three ₡ four 🦆 end', CHAR_LENGTH('two ñ three ₡ four 🦆 end')) = 'two ñ three ₡ four 🦆 end' AS INT)
----
1

query I
SELECT CAST(RIGHT('two ñ three ₡ four 🦆 end', CHAR_LENGTH('two ñ three ₡ four 🦆 end')) = 'two ñ three ₡ four 🦆 end' AS INT)
----
1

query I
SELECT CAST(RIGHT('two ñ three ₡ four 🦆 end', CHAR_LENGTH('two n three ₡ four 🦆 end')) = 'two n three ₡ four 🦆 end' AS INT)
