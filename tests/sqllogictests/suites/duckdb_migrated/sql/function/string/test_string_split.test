statement ok
DROP TABLE IF EXISTS documents

statement ok
DROP TABLE IF EXISTS strings_with_null

statement ok
DROP FUNCTION IF EXISTS ddb_string_split_compat

statement ok
CREATE FUNCTION ddb_string_split_compat AS (s, delim) -> CASE
    WHEN s IS NULL THEN NULL
    WHEN delim IS NULL THEN [s]
    WHEN delim = '' THEN REGEXP_SPLIT_TO_ARRAY(s, '')
    ELSE SPLIT(s, delim)
END

query T
SELECT ddb_string_split_compat(NULL, NULL)
----
NULL

query T
SELECT ddb_string_split_compat('hello world', ' ')
UNION ALL
SELECT ddb_string_split_compat(NULL, ' ')
UNION ALL
SELECT ddb_string_split_compat('a b c', NULL)
UNION ALL
SELECT ddb_string_split_compat('a b c', ' ')
----
["hello","world"]
NULL
["a b c"]
["a","b","c"]

statement ok
CREATE TABLE strings_with_null (s VARCHAR)

statement ok
INSERT INTO strings_with_null VALUES ('aba'), (NULL), ('ababa')

query T
SELECT UNNEST(ddb_string_split_compat(s, 'b')) FROM strings_with_null
----
a
a
a
a
a

query I
SELECT CAST(UNNEST(ddb_string_split_compat(NULL, ' ')) IS NULL AS INT) LIMIT 5
----

