statement ok
CREATE TABLE documents(id INT, s VARCHAR)

statement ok
INSERT INTO documents VALUES (1, 'baabbaa'), (2, 'aabbaab'), (3, 'ababababa'), (4, 'b🦆🦆bb🦆🦆'), (5, '🦆🦆bb🦆🦆b'), (6, '🦆b🦆b🦆b🦆b🦆')

query T
SELECT ss FROM (SELECT id, UNNEST(ddb_string_split_compat(s, 'bb')) AS ss FROM documents WHERE 1) AS q ORDER BY id
----
baa
aa
aa
aab
ababababa
b🦆🦆
🦆🦆
🦆🦆
🦆🦆b
🦆b🦆b🦆b🦆b🦆

query T
SELECT ss FROM (SELECT id, UNNEST(ddb_string_split_compat(s, 'bb')) AS ss FROM documents WHERE s LIKE 'b%') AS q ORDER BY id
----
baa
aa
b🦆🦆
🦆🦆

query T
SELECT string_agg(ss, 'bb') FROM (SELECT id, UNNEST(ddb_string_split_compat(s, 'bb')) AS ss FROM documents) AS q GROUP BY id ORDER BY id
----
baabbaa
aabbaab
ababababa
b🦆🦆bb🦆🦆
🦆🦆bb🦆🦆b
🦆b🦆b🦆b🦆b🦆

