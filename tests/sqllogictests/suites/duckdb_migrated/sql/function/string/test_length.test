DROP TABLE IF EXISTS strings

statement ok
CREATE TABLE strings(s VARCHAR)

statement ok
INSERT INTO strings VALUES ('hello'), ('world'), (NULL)

# normal length

query I
SELECT length(s) FROM strings ORDER BY s
----
5
5
NULL

# length after concat

query I
SELECT length(s || ' ' || '🦆') FROM strings ORDER BY s
----
7
7
NULL

# aliases work

query II
SELECT char_length('asdf'), CHARACTER_LENGTH('asdf')
----
4 4
