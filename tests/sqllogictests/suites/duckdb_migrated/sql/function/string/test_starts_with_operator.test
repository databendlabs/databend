       CAST(LEFT('hello world', CHAR_LENGTH('ha')) = 'ha' AS INT),
       CAST(LEFT('hello world', CHAR_LENGTH('hea')) = 'hea' AS INT),
       CAST(LEFT('hello world', CHAR_LENGTH('hela')) = 'hela' AS INT),
       CAST(LEFT('hello world', CHAR_LENGTH('hella')) = 'hella' AS INT),
       CAST(LEFT('hello world', CHAR_LENGTH('helloa')) = 'helloa' AS INT),
       CAST(LEFT('hello world', CHAR_LENGTH('hello a')) = 'hello a' AS INT),
       CAST(LEFT('hello world', CHAR_LENGTH('hello wa')) = 'hello wa' AS INT),
       CAST(LEFT('hello world', CHAR_LENGTH('hello woa')) = 'hello woa' AS INT),
       CAST(LEFT('hello world', CHAR_LENGTH('hello wora')) = 'hello wora' AS INT)
