# empty starts_with

query III
select CAST(LEFT('hello', CHAR_LENGTH('')) = '' AS INT), CAST(LEFT('', CHAR_LENGTH('')) = '' AS INT), CAST(LEFT(NULL, CHAR_LENGTH('')) = '' AS INT)
----
1	1	NULL

statement ok
CREATE TABLE strings(s VARCHAR, off INTEGER, length INTEGER);

statement ok
INSERT INTO strings VALUES ('hello', 1, 2), ('world', 2, 3), ('h', 1, 1), (NULL, 2, 2)

# Test first letter

query I
SELECT CAST(LEFT(s, CHAR_LENGTH('h')) = 'h' AS INT) FROM strings
----
1
0
1
NULL

# Test multiple letters

query I
SELECT CAST(LEFT(s, CHAR_LENGTH('he')) = 'he' AS INT) FROM strings
----
1
0
0
NULL

# Test no match

query I
SELECT CAST(LEFT(s, CHAR_LENGTH('he-man')) = 'he-man' AS INT) FROM strings
----
0
0
0
NULL

# Test NULL constant in different places

query I
SELECT CAST(LEFT(NULL, CHAR_LENGTH('h')) = 'h' AS INT) FROM strings
----
NULL
NULL
NULL
NULL

query I
SELECT CAST(LEFT(s, CHAR_LENGTH(NULL)) = NULL AS INT) FROM strings
----
NULL
NULL
NULL
NULL

query I
SELECT CAST(LEFT(NULL, CHAR_LENGTH(NULL)) = NULL AS INT) FROM strings
----
NULL
NULL
NULL
NULL

# Test empty pattern

query I
SELECT CAST(LEFT(s, CHAR_LENGTH('')) = '' AS INT) FROM strings
