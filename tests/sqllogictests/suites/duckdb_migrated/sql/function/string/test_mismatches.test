statement ok
DROP TABLE IF EXISTS string_pairs

statement ok
CREATE TABLE string_pairs(s VARCHAR, t VARCHAR)

statement ok
INSERT INTO string_pairs VALUES ('hello', 'world'), ('hallo', 'ola'), ('hello', ''), (NULL, NULL), ('', ''), ('bora', 'bora')

query T
SELECT concat(CASE
    WHEN s IS NULL OR t IS NULL THEN NULL
    WHEN char_length(s) <> char_length(t) OR char_length(s) = 0 THEN CAST('x' AS INT)
    ELSE
        (CASE WHEN substring(s, 1, 1) = substring(t, 1, 1) THEN 0 ELSE 1 END) +
        (CASE WHEN substring(s, 2, 1) = substring(t, 2, 1) THEN 0 ELSE 1 END) +
        (CASE WHEN substring(s, 3, 1) = substring(t, 3, 1) THEN 0 ELSE 1 END) +
        (CASE WHEN substring(s, 4, 1) = substring(t, 4, 1) THEN 0 ELSE 1 END) +
        (CASE WHEN substring(s, 5, 1) = substring(t, 5, 1) THEN 0 ELSE 1 END)
END, '')
FROM string_pairs
WHERE char_length(s) = char_length(t) AND char_length(s) > 0
ORDER BY s, t
----
0
4

