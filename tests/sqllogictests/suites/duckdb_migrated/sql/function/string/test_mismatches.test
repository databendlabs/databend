statement ok
CREATE TABLE strings(s VARCHAR)

statement ok
INSERT INTO strings VALUES ('hello'), ('hallo'), ('aloha'), ('world'), (NULL)

query T
SELECT concat(CASE
    WHEN s IS NULL OR 'hallo' IS NULL THEN NULL
    WHEN char_length(s) <> char_length('hallo') OR char_length(s) = 0 THEN CAST('x' AS INT)
    ELSE
        (CASE WHEN substring(s, 1, 1) = substring('hallo', 1, 1) THEN 0 ELSE 1 END) +
        (CASE WHEN substring(s, 2, 1) = substring('hallo', 2, 1) THEN 0 ELSE 1 END) +
        (CASE WHEN substring(s, 3, 1) = substring('hallo', 3, 1) THEN 0 ELSE 1 END) +
        (CASE WHEN substring(s, 4, 1) = substring('hallo', 4, 1) THEN 0 ELSE 1 END) +
        (CASE WHEN substring(s, 5, 1) = substring('hallo', 5, 1) THEN 0 ELSE 1 END)
END, '')
FROM strings
ORDER BY s
----
5
0
1
4
NULL

query T
SELECT CASE
    WHEN NULL IS NULL OR s IS NULL THEN NULL
    ELSE 0
END
FROM strings
ORDER BY s
----
NULL
NULL
NULL
NULL
NULL

