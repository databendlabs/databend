# Databend rewrite: fixed-width mismatch counts with substring comparisons.

statement ok
DROP TABLE IF EXISTS strings

query T
SELECT concat(CASE
    WHEN 'hallo' IS NULL OR 'hallo' IS NULL THEN NULL
    WHEN char_length('hallo') <> char_length('hallo') OR char_length('hallo') = 0 THEN CAST('x' AS INT)
    ELSE
        (CASE WHEN substring('hallo', 1, 1) = substring('hallo', 1, 1) THEN 0 ELSE 1 END) +
        (CASE WHEN substring('hallo', 2, 1) = substring('hallo', 2, 1) THEN 0 ELSE 1 END) +
        (CASE WHEN substring('hallo', 3, 1) = substring('hallo', 3, 1) THEN 0 ELSE 1 END) +
        (CASE WHEN substring('hallo', 4, 1) = substring('hallo', 4, 1) THEN 0 ELSE 1 END) +
        (CASE WHEN substring('hallo', 5, 1) = substring('hallo', 5, 1) THEN 0 ELSE 1 END)
END, '')
----
0

