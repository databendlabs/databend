DROP TABLE IF EXISTS strings

statement ok
CREATE TABLE strings(s VARCHAR)

statement ok
INSERT INTO strings VALUES ('twoñthree₡four🦆end')

query T
SELECT substring(s FROM 1 FOR 7) FROM strings
----
twoñthr

query T
