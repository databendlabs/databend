# like with table

statement ok
CREATE TABLE strings(s STRING, pat STRING);

statement ok
INSERT INTO strings VALUES ('abab', 'Ab%'), ('aaa', 'A_a'), ('aaa', '%b%')

query T
SELECT s FROM strings WHERE s LIKE 'ab%'
----
abab

query T
SELECT s FROM strings WHERE lower('aba') LIKE lower(pat)
----
abab
aaa
aaa

query T
SELECT s FROM strings WHERE lower('aba') NOT LIKE lower(pat)
----

query T
SELECT s FROM strings WHERE lower(s) LIKE lower(pat)
----
abab
aaa

query T
SELECT s FROM strings WHERE lower(s) NOT LIKE lower(pat)
----
aaa

# unicode

query B
SELECT lower('MÜHLEISEN') LIKE lower('mühleisen')
----
1

statement ok
CREATE TABLE unicode_strings(s STRING, pat STRING);

statement ok
INSERT INTO unicode_strings VALUES ('öäb', 'Ö%B'), ('aaÄ', 'A_ä'), ('aaa', '%b%')

query T
SELECT s FROM unicode_strings WHERE lower(s) LIKE lower(pat)
----
öäb
aaÄ

query T
SELECT s FROM unicode_strings WHERE lower(s) NOT LIKE lower(pat)
----
aaa
