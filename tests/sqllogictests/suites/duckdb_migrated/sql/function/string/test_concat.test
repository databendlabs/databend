world world
NULL

# unicode concat

query T
SELECT s || ' ' || '🦆' FROM strings ORDER BY s
----
hello 🦆
world 🦆
NULL

query T
SELECT s || ' ' || '🦆' FROM strings ORDER BY s
----
hello 🦆
world 🦆
NULL

# concat with constant NULL

query T
SELECT s || ' ' || '🦆' || NULL FROM strings ORDER BY s
----
