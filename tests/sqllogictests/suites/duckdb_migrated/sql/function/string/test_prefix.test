# test empty prefix removal

statement ok
INSERT INTO t0 VALUES ('a'), ('b'), ('d')

query I
SELECT COUNT(*) FROM t0 WHERE LEFT(t0.c0, CHAR_LENGTH('')) = '';
----
3

query TI
SELECT c0, CAST(LEFT(t0.c0, CHAR_LENGTH('')) = '' AS INT) FROM t0 WHERE c0 <> 'b' ORDER BY t0.c0;
----
a	1
d	1


# now with a NULL value

statement ok
INSERT INTO t0 VALUES (NULL)

query I
SELECT COUNT(*) FROM t0 WHERE LEFT(t0.c0, CHAR_LENGTH('')) = '';
----
3

query TI
SELECT c0, CAST(LEFT(t0.c0, CHAR_LENGTH('')) = '' AS INT) FROM t0 WHERE c0 IS NULL OR c0 <> 'b' ORDER BY c0 IS NOT NULL, t0.c0;
----
NULL	NULL
a	1
d	1
