statement ok
DROP TABLE IF EXISTS t0

query I
SELECT CAST(LEFT('abcd', CHAR_LENGTH('a')) = 'a' AS INT)
----
1

query I
SELECT CAST(LEFT('abcd', CHAR_LENGTH('ab')) = 'ab' AS INT)
----
1

query I
SELECT CAST(LEFT('abcd', CHAR_LENGTH('abc')) = 'abc' AS INT)
----
1

query I
SELECT CAST(LEFT('abcd', CHAR_LENGTH('abcd')) = 'abcd' AS INT)
----
1

query I
SELECT CAST(LEFT('abcd', CHAR_LENGTH('b')) = 'b' AS INT)
----
0

# "Inlined string"

query I
SELECT CAST(LEFT('abcdefgh', CHAR_LENGTH('a')) = 'a' AS INT)
----
1

query I
SELECT CAST(LEFT('abcdefgh', CHAR_LENGTH('ab')) = 'ab' AS INT)
----
1

query I
SELECT CAST(LEFT('abcdefgh', CHAR_LENGTH('abc')) = 'abc' AS INT)
----
1

query I
SELECT CAST(LEFT('abcdefgh', CHAR_LENGTH('abcd')) = 'abcd' AS INT)
----
1

query I
SELECT CAST(LEFT('abcdefgh', CHAR_LENGTH('abcde')) = 'abcde' AS INT)
----
1

query I
SELECT CAST(LEFT('abcdefgh', CHAR_LENGTH('b')) = 'b' AS INT)
----
0

# Longer (non-inlined) strings

query I
SELECT CAST(LEFT('abcdefghijklmnopqrstuvwxyz', CHAR_LENGTH('a')) = 'a' AS INT)
----
1

query I
SELECT CAST(LEFT('abcdefghijklmnopqrstuvwxyz', CHAR_LENGTH('ab')) = 'ab' AS INT)
----
1

query I
SELECT CAST(LEFT('abcdefghijklmnopqrstuvwxyz', CHAR_LENGTH('abc')) = 'abc' AS INT)
----
1

query I
SELECT CAST(LEFT('abcdefghijklmnopqrstuvwxyz', CHAR_LENGTH('abcd')) = 'abcd' AS INT)
----
1

query I
SELECT CAST(LEFT('abcdefghijklmnopqrstuvwxyz', CHAR_LENGTH('abcde')) = 'abcde' AS INT)
----
1

query I
SELECT CAST(LEFT('abcdefghijklmnopqrstuvwxyz', CHAR_LENGTH('b')) = 'b' AS INT)
----
0

query I
SELECT CAST(LEFT('abcdefghijklmnopqrstuvwxyz', CHAR_LENGTH('abcdefghijklmnopqrstuvwx')) = 'abcdefghijklmnopqrstuvwx' AS INT)
----
1

query I
SELECT CAST(LEFT('abcdefghijklmnopqrstuvwxyz', CHAR_LENGTH('abcfefghijklmnopqrstuvwx')) = 'abcfefghijklmnopqrstuvwx' AS INT)
----
0

# "Empty string and prefix"

query I
SELECT CAST(LEFT('', CHAR_LENGTH('aaa')) = 'aaa' AS INT)
----
0

query I
SELECT CAST(LEFT('aaa', CHAR_LENGTH('')) = '' AS INT)
----
1

# "Issue #572 alloc exception on empty table"

statement ok
CREATE TABLE t0(c0 VARCHAR)

query T
SELECT * FROM t0 WHERE LEFT(t0.c0, CHAR_LENGTH('')) = ''
----

