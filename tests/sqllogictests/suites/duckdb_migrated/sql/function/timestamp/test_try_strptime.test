query T
SELECT TRY_TO_TIMESTAMP('2022-04-07 18:12:15')
----
2022-04-07 18:12:15.000000

query T
SELECT TRY_TO_TIMESTAMP('2022-04-07T18:12:15')
----
2022-04-07 18:12:15.000000

query T
SELECT TRY_TO_DATETIME('2022-04-07 18:12:15')
----
2022-04-07 18:12:15.000000

query T
SELECT TRY_TO_DATE('2022-04-07')
----
2022-04-07

query T
SELECT TRY_TO_TIMESTAMP('bad')
----
NULL

query T
SELECT TRY_TO_DATETIME('bad')
----
NULL

query T
SELECT TRY_TO_DATE('bad')
----
NULL

query TT
SELECT TRY_TO_TIMESTAMP('2022-04-07 18:12:15'), TRY_TO_TIMESTAMP('bad')
----
2022-04-07 18:12:15.000000 NULL

query TT
SELECT TRY_TO_DATE('2022-04-07'), TRY_TO_DATE('bad')
----
2022-04-07 NULL

query T
SELECT TRY_TO_TIMESTAMP(NULL)
----
NULL
