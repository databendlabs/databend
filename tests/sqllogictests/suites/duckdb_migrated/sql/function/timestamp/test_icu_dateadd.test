query T
SELECT DATE_ADD('day', 1, TIMESTAMP '2021-12-01 13:54:48.123456')
----
2021-12-02 13:54:48.123456

query T
SELECT DATE_ADD('month', 1, TIMESTAMP '2021-12-01 13:54:48.123456')
----
2022-01-01 13:54:48.123456

query T
SELECT DATE_ADD('hour', 11, TIMESTAMP '2021-12-01 13:54:48.123456')
----
2021-12-02 00:54:48.123456

query T
SELECT DATE_ADD('minute', 6, TIMESTAMP '2021-12-01 13:54:48.123456')
----
2021-12-01 14:00:48.123456

query T
SELECT DATE_ADD('second', 23, TIMESTAMP '2021-12-01 13:54:48.123456')
----
2021-12-01 13:55:11.123456

query T
SELECT DATE_SUB('month', 1, TIMESTAMP '2021-12-01 13:54:48.123456')
----
2021-11-01 13:54:48.123456

query T
SELECT DATE_SUB('day', 32, TIMESTAMP '2021-12-01 13:54:48.123456')
----
2021-10-30 13:54:48.123456

query T
SELECT DATE_SUB('minute', 72, TIMESTAMP '2021-12-01 13:54:48.123456')
----
2021-12-01 12:42:48.123456

query T
SELECT DATE_SUB('second', 1, TIMESTAMP '2021-12-01 13:54:48.123456')
----
2021-12-01 13:54:47.123456

query T
SELECT DATE_ADD('day', NULL, TIMESTAMP '2021-12-01 13:54:48.123456')
----
NULL

query T
SELECT DATE_ADD('day', 1, NULL::TIMESTAMP)
----
NULL

query T
SELECT DATE_SUB('second', 1, NULL::TIMESTAMP)
----
NULL
