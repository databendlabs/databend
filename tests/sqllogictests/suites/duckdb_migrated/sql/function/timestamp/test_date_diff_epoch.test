query I
SELECT DATEDIFF('day', TIMESTAMP '1970-01-03 12:12:12', TIMESTAMP '1969-12-25 05:05:05')
----
-8

query I
SELECT DATEDIFF('hour', TIMESTAMP '1970-01-01 12:12:12', TIMESTAMP '1969-12-31 05:05:05')
----
-30

query I
SELECT DATEDIFF('minute', TIMESTAMP '1970-01-01 00:12:12', TIMESTAMP '1969-12-31 23:05:05')
----
-66

query I
SELECT DATEDIFF('second', TIMESTAMP '1970-01-01 00:00:12.456', TIMESTAMP '1969-12-31 23:59:05.123')
----
-66

query I
SELECT DATEDIFF('day', NULL::TIMESTAMP, TIMESTAMP '1970-01-01 00:00:00')
----
NULL
