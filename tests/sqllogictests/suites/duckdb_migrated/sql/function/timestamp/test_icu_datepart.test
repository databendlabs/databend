query I
SELECT DATE_PART(YEAR, TIMESTAMP '2021-01-01 00:00:00')
----
2021

query I
SELECT DATE_PART(MONTH, TIMESTAMP '2021-02-02 00:00:00')
----
2

query I
SELECT DATE_PART(DAY, TIMESTAMP '2021-12-25 00:00:00')
----
25

query I
SELECT EXTRACT(HOUR FROM TIMESTAMP '2021-11-15 02:30:00')
----
2

query I
SELECT EXTRACT(MINUTE FROM TIMESTAMP '2021-11-15 02:30:00')
----
30

query I
SELECT EXTRACT(SECOND FROM TIMESTAMP '2021-11-26 10:15:13.123456')
----
13

query I
SELECT DATE_PART(WEEK, TIMESTAMP '2019-01-06 04:03:02')
----
1

query I
SELECT DATE_PART(DOW, TIMESTAMP '1992-01-06 00:00:00')
----
1

query I
SELECT DATE_PART(ISODOW, TIMESTAMP '1992-01-12 00:00:00')
----
7

query I
SELECT DATE_PART(DOY, TIMESTAMP '2021-12-31 00:00:00')
----
365

query I
SELECT DATE_PART(ISOYEAR, TIMESTAMP '2022-01-01 00:00:41')
----
2021

query I
SELECT DATE_PART(YEARWEEK, TIMESTAMP '2022-01-01 00:00:41')
----
202152

query I
SELECT MILLENNIUM(TIMESTAMP '1992-02-02 02:02:03.123456')
----
2

query R
SELECT DATE_PART(EPOCH, TIMESTAMP '1962-07-31 12:20:48.123456')
----
-234185951.876544

query I
SELECT DATE_PART(HOUR, NULL::TIMESTAMP)
----
NULL

query R
SELECT DATE_PART(EPOCH, NULL::TIMESTAMP)
----
NULL
