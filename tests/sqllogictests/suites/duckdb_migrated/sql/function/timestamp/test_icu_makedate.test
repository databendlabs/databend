query T
SELECT TRY_TO_TIMESTAMP_TZ('2021-12-30 10:12:04.123+00:00')
----
2021-12-30 10:12:04.123000 +0000

query T
SELECT TRY_TO_TIMESTAMP_TZ('2021-12-30 10:12:04.123-05:00')
----
2021-12-30 10:12:04.123000 -0500

query T
SELECT TRY_TO_TIMESTAMP_TZ('2021-12-30 10:12:04.123+08:00')
----
2021-12-30 10:12:04.123000 +0800

query T
SELECT TRY_TO_TIMESTAMP_TZ('bad')
----
NULL

query T
SELECT TRY_TO_TIMESTAMP_TZ(NULL)
----
NULL

query TT
SELECT TRY_TO_TIMESTAMP_TZ('2021-12-30 10:12:04.123+00:00'),
       TRY_TO_TIMESTAMP_TZ('bad')
----
2021-12-30 10:12:04.123000 +0000 NULL
