query T
SELECT CAST(TRY_TO_TIMESTAMP_TZ('2021-12-01 13:54:48+00:00') AS TIMESTAMP)
----
2021-12-01 13:54:48.000000

query T
SELECT TIME_SLICE(CAST(TRY_TO_TIMESTAMP_TZ('2021-12-01 13:54:48+00:00') AS TIMESTAMP), 8, 'day')
----
2021-11-29 00:00:00.000000

query T
SELECT CAST(TRY_TO_TIMESTAMP_TZ('2021-12-01 13:54:48+08:00') AS TIMESTAMP)
----
2021-12-01 05:54:48.000000

query T
SELECT TIME_SLICE(CAST(TRY_TO_TIMESTAMP_TZ('2021-12-01 13:54:48+08:00') AS TIMESTAMP), 8, 'hour')
----
2021-12-01 00:00:00.000000

query T
SELECT TIME_SLICE(CAST(TRY_TO_TIMESTAMP_TZ('2021-12-01 13:54:48+08:00') AS TIMESTAMP), 8, 'minute')
----
2021-12-01 05:52:00.000000

query T
SELECT CAST(TRY_TO_TIMESTAMP_TZ('bad') AS TIMESTAMP)
----
NULL

query T
SELECT TIME_SLICE(CAST(TRY_TO_TIMESTAMP_TZ(NULL) AS TIMESTAMP), 8, 'day')
----
NULL
