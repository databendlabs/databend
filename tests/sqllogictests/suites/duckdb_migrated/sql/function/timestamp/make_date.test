query T
SELECT TRY_TO_DATE(CONCAT(CAST(2021 AS VARCHAR), '-', LPAD(CAST(12 AS VARCHAR), 2, '0'), '-', LPAD(CAST(30 AS VARCHAR), 2, '0')))
----
2021-12-30

query T
SELECT TRY_TO_DATE(CONCAT(CAST(2020 AS VARCHAR), '-', LPAD(CAST(2 AS VARCHAR), 2, '0'), '-', LPAD(CAST(29 AS VARCHAR), 2, '0')))
----
2020-02-29

query T
SELECT TRY_TO_DATE(CONCAT(CAST(2021 AS VARCHAR), '-', LPAD(CAST(13 AS VARCHAR), 2, '0'), '-', LPAD(CAST(1 AS VARCHAR), 2, '0')))
----
NULL

query T
SELECT TRY_TO_DATE(CONCAT(CAST(YEAR(DATE '1992-05-05') AS VARCHAR), '-', LPAD(CAST(MONTH(DATE '1992-05-05') AS VARCHAR), 2, '0'), '-', LPAD(CAST(DAY(DATE '1992-05-05') AS VARCHAR), 2, '0')))
----
1992-05-05

query TT
SELECT TRY_TO_DATE(CONCAT(CAST(2021 AS VARCHAR), '-', LPAD(CAST(12 AS VARCHAR), 2, '0'), '-', LPAD(CAST(30 AS VARCHAR), 2, '0'))),
       TRY_TO_DATE(NULL)
----
2021-12-30 NULL

query T
SELECT TRY_TO_DATE(NULL)
