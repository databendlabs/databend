query I
SELECT EXTRACT(second FROM TIMESTAMP '1993-08-14 08:22:33.420')
----
33

query I
SELECT EXTRACT(minute FROM TIMESTAMP '1993-08-14 08:22:33.420')
----
22

query I
SELECT CAST((DATE_PART(EPOCH, TIMESTAMP '1993-08-14 08:22:33.420') - FLOOR(DATE_PART(EPOCH, TIMESTAMP '1993-08-14 08:22:33.420'))) * 1000 AS BIGINT)
----
420

query I
SELECT CAST((DATE_PART(EPOCH, TIMESTAMP '1993-08-14 08:22:33.420') - FLOOR(DATE_PART(EPOCH, TIMESTAMP '1993-08-14 08:22:33.420'))) * 1000000 AS BIGINT)
----
420000

query II
SELECT EXTRACT(second FROM TIMESTAMP '1993-08-14 08:22:33.420'),
       CAST((DATE_PART(EPOCH, TIMESTAMP '1993-08-14 08:22:33.420') - FLOOR(DATE_PART(EPOCH, TIMESTAMP '1993-08-14 08:22:33.420'))) * 1000 AS BIGINT)
----
33 420

query I
SELECT EXTRACT(second FROM NULL::TIMESTAMP)
----
NULL

query I
SELECT CAST((DATE_PART(EPOCH, NULL::TIMESTAMP) - FLOOR(DATE_PART(EPOCH, NULL::TIMESTAMP))) * 1000000 AS BIGINT)
----
NULL
