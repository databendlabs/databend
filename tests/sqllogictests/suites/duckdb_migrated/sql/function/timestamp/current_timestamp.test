query I
SELECT EXTRACT(MILLENNIUM FROM NOW())
----
3

query T
SELECT typeof(CURRENT_TIMESTAMP)
----
TIMESTAMP

query T
SELECT typeof(NOW())
----
TIMESTAMP

query T
SELECT CAST(CURRENT_TIMESTAMP = NOW() AS STRING)
----
true

query T
SELECT CAST(CAST(CURRENT_TIMESTAMP AS DATE) = CURRENT_DATE() AS STRING)
----
true

query T
SELECT CAST(NOW() >= CURRENT_TIMESTAMP - INTERVAL '1 second' AS STRING)
----
true

query T
SELECT CAST(NOW() <= CURRENT_TIMESTAMP + INTERVAL '1 second' AS STRING)
----
true
