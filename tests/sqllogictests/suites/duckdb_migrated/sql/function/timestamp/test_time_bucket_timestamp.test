query T
SELECT TIME_SLICE(TIMESTAMP '2019-02-28 01:23:45.678', 8, 'day')
----
2019-02-25 00:00:00.000000

query T
SELECT TIME_SLICE(TIMESTAMP '2019-02-28 01:23:45.678', 8, 'day', 'end')
----
2019-03-05 00:00:00.000000

query T
SELECT TIME_SLICE(TIMESTAMP '2019-02-28 01:23:45.678', 8, 'week')
----
2019-01-21 00:00:00.000000

query T
SELECT TIME_SLICE(TIMESTAMP '2019-02-28 01:23:45.678', 8, 'month')
----
2018-09-01 00:00:00.000000

query T
SELECT TIME_SLICE(TIMESTAMP '2019-02-28 01:23:45.678', 8, 'year')
----
2018-01-01 00:00:00.000000

query T
SELECT TIME_SLICE(TIMESTAMP '2019-02-28 01:23:45.678', 8, 'hour')
----
2019-02-28 00:00:00.000000

query T
SELECT TIME_SLICE(TIMESTAMP '2019-02-28 01:23:45.678', 8, 'hour', 'end')
----
2019-02-28 08:00:00.000000

query T
SELECT TIME_SLICE(TIMESTAMP '2019-02-28 01:23:45.678', 8, 'minute')
----
2019-02-28 01:20:00.000000

query T
SELECT TIME_SLICE(TIMESTAMP '2019-02-28 01:23:45.678', 8, 'second')
----
2019-02-28 01:23:44.000000

query T
SELECT TIME_SLICE(NULL::TIMESTAMP, 8, 'day')
----
NULL
