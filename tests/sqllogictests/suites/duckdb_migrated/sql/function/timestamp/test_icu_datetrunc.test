query T
SELECT DATE_TRUNC('year', TIMESTAMP '1992-02-02 02:02:03.123456')
----
1992-01-01

query T
SELECT DATE_TRUNC('quarter', TIMESTAMP '2020-12-02 04:03:02')
----
2020-10-01

query T
SELECT DATE_TRUNC('month', TIMESTAMP '1992-02-02 02:02:03.123456')
----
1992-02-01

query T
SELECT DATE_TRUNC('week', TIMESTAMP '2019-01-06 04:03:02')
----
2018-12-31

query T
SELECT DATE_TRUNC('week', TIMESTAMP '2020-01-01 04:03:02')
----
2019-12-30

query T
SELECT DATE_TRUNC('day', TIMESTAMP '2019-01-06 04:03:02')
----
2019-01-06 00:00:00.000000

query T
SELECT DATE_TRUNC('hour', TIMESTAMP '2019-01-06 04:03:02')
----
2019-01-06 04:00:00.000000

query T
SELECT DATE_TRUNC('minute', TIMESTAMP '2019-01-06 04:03:02')
----
2019-01-06 04:03:00.000000

query T
SELECT DATE_TRUNC('second', TIMESTAMP '2019-01-06 04:03:02.5')
----
2019-01-06 04:03:02.000000

query T
SELECT DATE_TRUNC('year', NULL::TIMESTAMP)
----
NULL

query T
SELECT DATE_TRUNC('day', NULL::TIMESTAMP)
----
NULL
