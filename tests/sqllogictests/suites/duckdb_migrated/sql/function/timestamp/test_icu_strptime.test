query T
SELECT TRY_TO_TIMESTAMP_TZ('2022-04-07 18:12:15+00:00')
----
2022-04-07 18:12:15.000000 +0000

query T
SELECT TRY_TO_TIMESTAMP_TZ('2022-04-07T18:12:15Z')
----
2022-04-07 18:12:15.000000 +0000

query T
SELECT TRY_TO_TIMESTAMP_TZ('2022-04-07 18:12:15+08:00')
----
2022-04-07 18:12:15.000000 +0800

query T
SELECT TRY_TO_TIMESTAMP_TZ('bad')
----
NULL

query T
SELECT TRY_TO_TIMESTAMP_TZ(NULL)
----
NULL

query TT
SELECT TRY_TO_TIMESTAMP_TZ('2022-04-07 18:12:15+00:00'),
       TRY_TO_TIMESTAMP_TZ('bad')
----
2022-04-07 18:12:15.000000 +0000 NULL
