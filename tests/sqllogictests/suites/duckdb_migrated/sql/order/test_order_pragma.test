DROP TABLE IF EXISTS test

statement ok
CREATE TABLE test (a INTEGER, b INTEGER);

statement ok
INSERT INTO test VALUES (11, 22), (12, 21), (13, 22);

# default is ORDER BY ASC

query I
SELECT a FROM test ORDER BY a
----
