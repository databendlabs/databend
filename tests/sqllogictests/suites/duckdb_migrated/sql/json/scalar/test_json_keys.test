statement ok
create table t1 as
select range, case when range % 2 = 0 then '{"duck": 42}' else '{"duck": 42, "goose": 43}' end j
from generate_series(0, 9999)

query TT
select range % 2 g, sum(length(json_object_keys(j))) c
from t1
group by g
order by 1, 2
----
0	5000
1	10000

statement ok
create table t2 as
select range, '{"duck": {"key1": 42}, "goose": {"key1": 42, "key2": 43}}' j
from generate_series(0, 9999)

