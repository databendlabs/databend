DROP TABLE IF EXISTS testjson

statement ok
CREATE TABLE testjson AS SELECT '{ "key" : "value" }'::JSON AS example;

query I
SELECT (SELECT (example)->k AS v FROM (SELECT 'key' AS k) keys)
FROM testjson;
----
"value"

