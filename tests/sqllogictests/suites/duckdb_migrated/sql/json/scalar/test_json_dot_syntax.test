# select ('{"my_field": {"my_nested_field": ["goose", "duck"]}}'::JSON).my_field.my_nested_field[-1]
# ----
# "duck"

# array slicing doesn't work (yet) for json extract
# this looks a bit weird, but this actually does a string slice

query T
select ('{"my_field": {"my_nested_field": ["goose", "duck"]}}'::JSON).my_field.my_nested_field[0:1]
----
[

query T
select parse_json('{"my_field": {"my_nested_field": ["goose", "duck"]}}').my_field.my_nested_field[1]
----
"duck"

query T
select parse_json('{"my_field": {"my_nested_field": ["goose", "duckduckduckduck"]}}').my_field.my_nested_field[1]
----
"duckduckduckduck"

query T
select ('{"my_field": {"my_nested_field": ["goose", "duckduckduckduck"]}}'::JSON).my_field.my_nested_field[1]
----
"duckduckduckduck"

query T
select parse_json('{"my_field": {"my_nested_field": ["goose", "duckduckduckduck"]}}').my_field.my_nested_field[1]
----
"duckduckduckduck"

# doesn't work

query T
select parse_json('[1, 2, 42]')."2"
----
NULL

# works!

query T
select parse_json('[1, 2, 42]')[2]
----
42

query T
select parse_json('[1, 2, 42]')[2]::text
----
42

# chained

query T
select ('{"my_field": {"my_nested_field": ["goose", "duck"]}}'::JSON).my_field.my_nested_field[1]
----
"duck"

# some sqlite tests

query T
SELECT parse_json('{"a":2,"c":[4,5,{"f":7}]}').c
----
[4,5,{"f":7}]

query T
SELECT parse_json('{"a":2,"c":[4,5,{"f":7}]}').c[2]
----
{"f":7}

query T
SELECT parse_json('{"a":2,"c":[4,5,{"f":7}]}').c[2].f
----
7

query T
SELECT parse_json('{"a":2,"c":[4,5,{"f":7}]}').x
----
NULL

statement ok
CREATE TABLE obj(x varchar);

statement ok
INSERT INTO obj VALUES('{"a":1,"b":2}');

query T
SELECT parse_json(x).b FROM obj;
----
2

query T
SELECT parse_json(x)."b" FROM obj;
----
2

statement ok
CREATE TABLE t12(x varchar);

statement ok
INSERT INTO t12(x) VALUES(
'{"settings":
    {"layer2":
       {"hapax.legomenon":
          {"forceDisplay":true,
           "transliterate":true,
           "add.footnote":true,
           "summary.report":true},
        "dis.legomenon":
          {"forceDisplay":true,
           "transliterate":false,
           "add.footnote":false,
           "summary.report":true},
        "tris.legomenon":
          {"forceDisplay":true,
           "transliterate":false,
           "add.footnote":false,
           "summary.report":false}
       }
    }
 }');

query T
SELECT parse_json(x).settings.layer2."tris.legomenon"."summary.report" FROM t12;
----
0

query T
SELECT (x::JSON).settings.layer2."tris.legomenon"."summary.report" FROM t12;
----
0

# this will be upcast to JSON, cannot parse 'bar'

statement error
SELECT parse_json('{"foo": "bar"}').foo = 'bar';

query T
SELECT parse_json('{"foo": "bar"}').foo = '"bar"';
----
1

query T
SELECT parse_json('{"foo": 1}').foo = 1;
----
1

query T
SELECT parse_json('{"foo": "bar"}') = {foo: 'bar'}
----
1
