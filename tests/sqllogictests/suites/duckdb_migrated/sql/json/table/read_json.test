# {"id":1,"name":["O","Brother,","Where","Art","Thou?"]}
# {"id":2,"name":["Home","for","the","Holidays"]}
# {"id":3,"name":["The","Firm"]}
# {"id":4,"name":["Broadcast","News"]}
# {"id":5,"name":["Raising","Arizona"]}

# at level one we get JSON and JSON

# TODO: unsupported feature
# query II
# SELECT * FROM read_json_auto('{DATA_DIR}/json/with_list.json', maximum_depth=1)
# ----
# 1	["O","Brother,","Where","Art","Thou?"]
# 2	["Home","for","the","Holidays"]
# 3	["The","Firm"]
# 4	["Broadcast","News"]
# 5	["Raising","Arizona"]

# at level 2 we get BIGINT and JSON[]

# TODO: unsupported feature
# query II
# SELECT * FROM read_json_auto('{DATA_DIR}/json/with_list.json', maximum_depth=2)
# ----
# 1	["O", "Brother,", "Where", "Art", "Thou?"]
# 2	["Home", "for", "the", "Holidays"]
# 3	["The", "Firm"]
# 4	["Broadcast", "News"]
# 5	["Raising", "Arizona"]

# at level 3 it's fully detected, and we get BIGINT and VARCHAR[]

# TODO: unsupported feature
# query II
# SELECT * FROM read_json_auto('{DATA_DIR}/json/with_list.json', maximum_depth=3)
