statement ok
DROP TABLE IF EXISTS tbl

statement ok
begin transaction;

statement ok
create table tbl as select val from (
	select {
		'a': '01010101000'::BIT,
		'b': true,
		'c': NULL
	} val
), range(0, 3);

query I nosort result
select * from tbl;
----

