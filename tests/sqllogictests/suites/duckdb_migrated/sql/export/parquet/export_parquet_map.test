statement ok
DROP TABLE IF EXISTS unsupported_key

statement ok
DROP TABLE IF EXISTS unsupported_value

statement ok
begin transaction;

statement ok
create table unsupported_key as select val from (
	select MAP {
		'hello': '01010101000'::BIT,
		'HELLO': NULL::BIT
	} val
), range(0, 3);

statement ok
create table unsupported_value as select val from (
	select MAP {
		'01010101000'::BIT: 'hello',
		'11110111101'::BIT: 'world'
	} val
), range(0, 3);

query I nosort key
select * from unsupported_key;
----

query I nosort value
select * from unsupported_value;
----

# now export the db

statement ok
ROLLBACK

query I nosort key
select * from unsupported_key;
----

query I nosort value
select * from unsupported_value;
----
