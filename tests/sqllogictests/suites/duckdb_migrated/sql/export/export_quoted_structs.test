statement ok
DROP TABLE IF EXISTS a

# create a bunch of tables with data and views
statement ok
BEGIN TRANSACTION

# 'end' is a keyword, this has to be quoted

statement ok
create table a (s STRUCT("end" VARCHAR));

statement ok
insert into a values ({"end":'hello'});

query I
select * from a
----
{'end': hello}

