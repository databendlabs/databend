# filter after top-n

query IIII
SELECT * FROM (
	SELECT * FROM test ORDER BY j DESC LIMIT 2
) WHERE i=8
----
8	9	10	-8

query I
SELECT l FROM (
	SELECT * FROM test ORDER BY j DESC LIMIT 2
) WHERE k=10
----
-8

