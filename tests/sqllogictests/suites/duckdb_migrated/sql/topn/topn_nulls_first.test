DROP TABLE IF EXISTS topn_nulls

statement ok
CREATE TABLE topn_nulls(v INTEGER)

statement ok
INSERT INTO topn_nulls
SELECT CASE WHEN i % 3 = 0 THEN NULL ELSE i END
FROM range(0, 12) tbl(i)

