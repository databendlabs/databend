statement ok
DROP TABLE IF EXISTS t1

query I
SELECT COUNT(*) FROM (SELECT * FROM range(0, 1000000) tbl(i) UNION ALL SELECT * FROM range(0, 1000000) tbl(i)) tbl(i)
----
2000000

statement ok
CREATE TABLE t1 AS SELECT COUNT(*) FROM (SELECT * FROM range(0, 1000000) tbl(i) UNION ALL SELECT * FROM range(0, 1000000) tbl(i)) tbl(i)

query I
SELECT * FROM t1
----
2000000

query I
