# Empty binary should fail
statement error
SELECT '0b'::INT

statement error
SELECT '0b2'::INT

statement error
SELECT '0b10105'::INT

statement error
SELECT '0b-1'::INT

statement error
SELECT '-0b1'::INT

# Allow underscores as digit separators

# But dont allow them at the start or end

statement error
SELECT '0b_1'::INT

statement error
SELECT '0b1_0_'::INT

statement error
SELECT '0b_1_0'::INT

# Test limits

statement error
SELECT '0b00000000000000000000000000000000111111111'::TINYINT

statement error
SELECT '0b11111111111111111111111111111111'::INT

statement error
SELECT '0b1111111111111111111111111111111111111111111111111111111111111111'::BIGINT

