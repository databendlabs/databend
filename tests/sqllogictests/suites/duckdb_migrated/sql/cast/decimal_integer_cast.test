query I
SELECT CAST(0.55 AS TINYINT) as x;
----
1

query I
SELECT CAST(-0.55 AS TINYINT) as x;
----
-1

query I
SELECT CAST(0.55 AS SMALLINT) as x;
----
1

query I
SELECT CAST(-0.55 AS SMALLINT) as x;
----
-1

query I
SELECT CAST(0.55 AS INTEGER) as x;
----
1

query I
SELECT CAST(-0.55 AS INTEGER) as x;
----
-1

query I
SELECT CAST(0.55 AS BIGINT) as x;
----
1

query I
SELECT CAST(-0.55 AS BIGINT) as x;
----
-1

