#                numeric to bitstring
# ---------------------------------------------------

#  bitstrings that are too large for casted-to type
# ---------------------------------------------------

statement error
SELECT bitstring('1', 9)::TINYINT;

statement error
SELECT bitstring('1', 17)::SMALLINT;

statement error
SELECT bitstring('1', 33)::INT;

statement error
SELECT bitstring('1', 65)::BIGINT;

