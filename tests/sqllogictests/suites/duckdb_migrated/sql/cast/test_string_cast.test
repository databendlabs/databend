----
NULL

# Casting decimal strings to integral types should round to be consistent.

query I
SELECT '0.5'::TINYINT;
----
1

query I
SELECT '-0.5'::TINYINT;
----
-1

query I
SELECT '0.5'::SMALLINT;
----
1

query I
SELECT '-0.5'::SMALLINT;
----
-1

query I
SELECT '0.5'::INTEGER;
----
1

query I
SELECT '-0.5'::INTEGER;
----
-1

query I
SELECT '0.5'::BIGINT;
----
1

