# Error cases

# Cannot cast unnamed struct to MAP

statement error
SELECT (1, 2, 3)::MAP(INT, INT);

statement error
SELECT col::MAP(INT, INT)
FROM (VALUES ({"duck": 1}),({"goose": 2}))
AS tab(col);

statement error
SELECT {"number": 'not_a_number'}::MAP(VARCHAR, INT);

