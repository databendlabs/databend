# Synthetic workload derived from a production hang tail.
# Keep this file anonymized: schema, table, column, and literal names are generic.
statement ok
drop database if exists synthetic_load_src

statement ok
drop database if exists synthetic_load_stage

statement ok
drop database if exists synthetic_load_orig

statement ok
