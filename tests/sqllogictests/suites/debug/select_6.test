create or replace table synthetic_load_stage.discharge_record as
select
    concat('org_', to_string(number % 4)) as org_id,
    concat('source_', to_string(number % 3)) as source_code,
    concat('patient_', to_string(number % 120)) as patient_token,
    concat('visit_', to_string(number % 240)) as visit_id,
    to_timestamp('2026-05-29 00:00:00') + number as upload_time,
    concat('payload_', to_string(number)) as payload
from numbers(360)

statement ok
create or replace table synthetic_load_proc.unq_discharge_record like synthetic_load_stage.discharge_record

statement ok
insert into synthetic_load_proc.unq_discharge_record
select * from synthetic_load_stage.discharge_record
where upload_time >= date_sub(day, 0, to_date('2026-05-29', 'yyyy-mm-dd'))
qualify row_number() over (
    partition by concat(coalesce(org_id, ''), '|', coalesce(source_code, ''), '|', coalesce(patient_token, ''), '|', coalesce(visit_id, ''))
    order by upload_time desc
) = 1

