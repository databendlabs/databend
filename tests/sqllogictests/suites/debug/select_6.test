statement ok
create or replace table synthetic_load_src.visit_record as
select
    concat('org_', to_string(number % 4)) as org_id,
    concat('visit_', to_string(number)) as visit_id,
    concat('person_', to_string(number % 80)) as person_token,
    concat('patient_', to_string(number % 120)) as patient_token,
    to_timestamp('2026-01-01 00:00:00') + number * 3600 as visit_time,
    18 + number % 72 as age_year
from numbers(240)

statement ok
create or replace table synthetic_load_src.diagnosis_record as
select
    concat('org_', to_string(number % 4)) as org_id,
    concat('visit_', to_string(number % 240)) as visit_id,
    if(number % 3 = 0, 'Y', 'N') as primary_flag,
    if(number % 4 = 0, '0', '1') as diagnosis_rank,
    if(number % 4 = 0, '1', '2') as diagnosis_sort_no,
    case number % 5
        when 0 then concat('A10.', to_string(number % 7))
        when 1 then concat('B20.', to_string(number % 7))
        else concat('Z90.', to_string(number % 7))
    end as diagnosis_code,
    case number % 5
        when 0 then 'signal_alpha core'
        when 1 then 'signal_beta marker'
        when 2 then 'signal_gamma marker'
        when 3 then 'signal_delta marker'
        else 'signal_epsilon marker'
    end as diagnosis_label,
    to_timestamp('2026-01-01 00:00:00') + number * 1800 as diagnosis_time
from numbers(480)

statement ok
create or replace table synthetic_load_src.order_detail as
select
    concat('org_', to_string(number % 4)) as org_id,
    concat('visit_', to_string(number % 240)) as visit_id,
    case number % 6
        when 0 then 'agent_class_a token_a'
        when 1 then 'agent_class_b token_b'
        when 2 then 'agent_class_c token_c'
        when 3 then 'agent_class_d token_d'
        when 4 then 'agent_class_e token_e'
        else 'unrelated_agent'
    end as order_item_label,
    to_timestamp('2026-01-05 00:00:00') + number * 7200 as apply_time
from numbers(360)

statement ok
create or replace table synthetic_load_src.exam_report_detail as
select
    concat('patient_', to_string(number % 120)) as patient_token,
    to_timestamp('2026-01-03 00:00:00') + number * 3600 as exam_time,
    case number % 3
        when 0 then 'panel_alpha'
        when 1 then 'panel_beta'
        else 'panel_gamma'
    end as exam_item_name,
    concat('detail_', to_string(number % 9)) as exam_detail_item_name,
    concat('result_', to_string(number % 11)) as result_value,
    concat('range_', to_string(number % 4)) as reference_range
from numbers(300)

statement ok
create or replace table synthetic_load_src.free_text_record as
select
    number as note_id,
    concat('note_', to_string(number)) as note_text,
    to_timestamp('2026-01-01 00:00:00') + number as created_at
from numbers(16)

statement ok
create or replace table synthetic_load_stage.basic_landing as
select
    concat('org_name_', to_string(number % 4)) as org_name,
    concat('org_', to_string(number % 4)) as org_id,
    to_timestamp('2026-05-29 00:00:00') + number as upload_time,
    concat('source_', to_string(number % 3)) as source_code,
    concat('source_name_', to_string(number % 3)) as source_name,
    concat('business_', to_string(number)) as business_id,
    concat('person_', to_string(number % 80)) as person_token,
    concat('visit_', to_string(number % 240)) as visit_id,
    to_timestamp('2026-05-01 00:00:00') + number * 60 as event_time,
    concat('raw_status_', to_string(number % 3)) as status_code,
    concat('raw_status_name_', to_string(number % 3)) as status_name,
    concat('raw_type_', to_string(number % 4)) as type_code,
    concat('raw_type_name_', to_string(number % 4)) as type_name,
    concat('raw_channel_', to_string(number % 5)) as channel_code,
    concat('raw_channel_name_', to_string(number % 5)) as channel_name,
    concat('raw_method_', to_string(number % 2)) as method_code,
    concat('raw_method_name_', to_string(number % 2)) as method_name,
    number % 1000 as amount,
    1 + number % 5 as quantity,
    to_timestamp('2026-05-29 00:00:00') + number * 2 as detail_update_time,
    concat('batch_', to_string(number % 6)) as default_batch
from numbers(512)

statement ok
create or replace table synthetic_load_stage.dict_summary as
select * from (
    values
        ('status', 'raw_status_name_0', 1),
        ('status', 'raw_status_name_1', 1),
        ('type', 'raw_type_name_0', 1),
        ('type', 'raw_type_name_1', 1),
        ('channel', 'raw_channel_name_0', 1),
        ('channel', 'raw_channel_name_1', 1),
        ('method', 'raw_method_name_0', 1),
        ('method', 'raw_method_name_1', 1)
) as v(dic_domain, raw_name, dic_cnt)

statement ok
create or replace table synthetic_load_stage.dict_value as
select * from (
    values
        ('status', 'raw_status_name_0', 'std_status_0', 'standard_status_0'),
        ('status', 'raw_status_name_1', 'std_status_1', 'standard_status_1'),
        ('type', 'raw_type_name_0', 'std_type_0', 'standard_type_0'),
        ('type', 'raw_type_name_1', 'std_type_1', 'standard_type_1'),
        ('channel', 'raw_channel_name_0', 'std_channel_0', 'standard_channel_0'),
        ('channel', 'raw_channel_name_1', 'std_channel_1', 'standard_channel_1'),
        ('method', 'raw_method_name_0', 'std_method_0', 'standard_method_0'),
        ('method', 'raw_method_name_1', 'stdnull', 'stdnull')
) as v(dic_domain, raw_name, dic_val_code, dic_val_name)

