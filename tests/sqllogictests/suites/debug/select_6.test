query I
select count() from (
with diag_scan as (
    select
        org_id,
        visit_id,
        max(case when primary_flag = 'Y' and diagnosis_rank = '0' and (diagnosis_code like 'A10%' or diagnosis_code like 'B20%' or diagnosis_label regexp 'signal_alpha|signal_beta') then 1 else 0 end) as is_target,
        max(case when diagnosis_label regexp 'signal_alpha' then 1 else 0 end) as s1,
        max(case when diagnosis_label regexp 'signal_beta' then 1 else 0 end) as s2,
        max(case when diagnosis_label regexp 'signal_gamma' then 1 else 0 end) as s3,
        max(case when diagnosis_label regexp 'signal_delta' then 1 else 0 end) as s4,
        max(case when diagnosis_label regexp 'signal_epsilon' then 1 else 0 end) as s5
    from synthetic_load_src.diagnosis_record
    where diagnosis_time >= '2026-01-01'
      and diagnosis_time < '2026-05-01'
      and (
        primary_flag = 'Y' and diagnosis_rank = '0' and (diagnosis_code like 'A10%' or diagnosis_code like 'B20%' or diagnosis_label regexp 'signal_alpha|signal_beta')
        or diagnosis_label regexp 'signal_alpha|signal_beta|signal_gamma|signal_delta|signal_epsilon'
      )
    group by org_id, visit_id
),
target_visit as (
    select org_id, visit_id, s1, s2, s3, s4, s5 from diag_scan where is_target = 1
),
visit_person as (
    select distinct org_id, visit_id, person_token from synthetic_load_src.visit_record where person_token <> ''
),
target_visit_p as (
    select vp.person_token, tv.org_id, tv.visit_id, tv.s1, tv.s2, tv.s3, tv.s4, tv.s5
    from target_visit as tv
    inner join visit_person as vp on tv.org_id = vp.org_id and tv.visit_id = vp.visit_id
),
person_sym as (
    select person_token, max(s1) as p1, max(s2) as p2, max(s3) as p3, max(s4) as p4, max(s5) as p5
    from target_visit_p
    group by person_token
),
sym_cnt as (
    select sum(p1) as c1, sum(p2) as c2, sum(p3) as c3, sum(p4) as c4, sum(p5) as c5 from person_sym
),
sym_long as (
    select 'signal_alpha' as feature_name, 1 as sidx, c1 as cnt from sym_cnt
    union all select 'signal_beta', 2, c2 from sym_cnt
    union all select 'signal_gamma', 3, c3 from sym_cnt
    union all select 'signal_delta', 4, c4 from sym_cnt
    union all select 'signal_epsilon', 5, c5 from sym_cnt
),
top5 as (
    select feature_name, sidx, cnt, row_number() over (order by cnt desc, sidx) as rk from sym_long
),
visit_agent as (
    select
        o.org_id,
        o.visit_id,
        max(case when o.order_item_label regexp 'agent_class_a|token_a' then 1 else 0 end) as has_a,
        max(case when o.order_item_label regexp 'agent_class_b|token_b' then 1 else 0 end) as has_b,
        max(case when o.order_item_label regexp 'agent_class_c|token_c' then 1 else 0 end) as has_c,
        max(case when o.order_item_label regexp 'agent_class_d|token_d' then 1 else 0 end) as has_d,
        max(case when o.order_item_label regexp 'agent_class_e|token_e' then 1 else 0 end) as has_e
    from synthetic_load_src.order_detail as o
    inner join target_visit as tv on o.org_id = tv.org_id and o.visit_id = tv.visit_id
    where o.order_item_label regexp 'agent_class_a|token_a|agent_class_b|token_b|agent_class_c|token_c|agent_class_d|token_d|agent_class_e|token_e'
    group by o.org_id, o.visit_id
),
joined as (
    select tvp.person_token, tvp.s1, tvp.s2, tvp.s3, tvp.s4, tvp.s5, va.has_a, va.has_b, va.has_c, va.has_d, va.has_e
    from target_visit_p as tvp
    inner join visit_agent as va on tvp.org_id = va.org_id and tvp.visit_id = va.visit_id
),
cat_long as (
    select 'class_a' as cat, 1 as cat_sort, person_token, has_a as flag, s1, s2, s3, s4, s5 from joined
    union all select 'class_b', 2, person_token, has_b, s1, s2, s3, s4, s5 from joined
    union all select 'class_c', 3, person_token, has_c, s1, s2, s3, s4, s5 from joined
    union all select 'class_d', 4, person_token, has_d, s1, s2, s3, s4, s5 from joined
    union all select 'class_e', 5, person_token, has_e, s1, s2, s3, s4, s5 from joined
    union all select 'total', 9, person_token, 1, s1, s2, s3, s4, s5 from joined
),
cat_person as (
    select cat, cat_sort, person_token, max(flag * s1) as h1, max(flag * s2) as h2, max(flag * s3) as h3, max(flag * s4) as h4, max(flag * s5) as h5
    from cat_long
    group by cat, cat_sort, person_token
),
cat_agg as (
    select cat, cat_sort, sum(h1) as n1, sum(h2) as n2, sum(h3) as n3, sum(h4) as n4, sum(h5) as n5
    from cat_person
    group by cat, cat_sort
),
cat_long_cnt as (
    select cat, cat_sort, 1 as sidx, n1 as cnt from cat_agg
    union all select cat, cat_sort, 2, n2 from cat_agg
    union all select cat, cat_sort, 3, n3 from cat_agg
    union all select cat, cat_sort, 4, n4 from cat_agg
    union all select cat, cat_sort, 5, n5 from cat_agg
),
cat_cell as (
    select cl.cat, cl.cat_sort, t.rk, cl.cnt from cat_long_cnt as cl inner join top5 as t on cl.sidx = t.sidx
),
cat_pivot as (
    select
        cat,
        cat_sort,
        coalesce(sum(case when rk = 1 then cnt end), 0) as r1,
        coalesce(sum(case when rk = 2 then cnt end), 0) as r2,
        coalesce(sum(case when rk = 3 then cnt end), 0) as r3,
        coalesce(sum(case when rk = 4 then cnt end), 0) as r4,
        coalesce(sum(case when rk = 5 then cnt end), 0) as r5
    from cat_cell
    group by cat, cat_sort
)
select metric_group, rank_1, rank_2, rank_3, rank_4, rank_5
from (
    select 0 as sort_key, 'feature_name' as metric_group, max(case when rk = 1 then feature_name end) as rank_1, max(case when rk = 2 then feature_name end) as rank_2, max(case when rk = 3 then feature_name end) as rank_3, max(case when rk = 4 then feature_name end) as rank_4, max(case when rk = 5 then feature_name end) as rank_5
    from top5
    union all
    select cat_sort, cat, cast(r1 as string), cast(r2 as string), cast(r3 as string), cast(r4 as string), cast(r5 as string)
    from cat_pivot
) as x
order by sort_key
) as tlimit
----
7

query I
select * from (
with cte1 as (
    select person_token, t1.visit_id, diagnosis_label, diagnosis_time, t1.org_id
    from synthetic_load_src.diagnosis_record as t1
    left outer join synthetic_load_src.visit_record as t2 on t1.visit_id = t2.visit_id and t1.org_id = t2.org_id
    where age_year > 18
      and (t1.diagnosis_code regexp 'A10|B20' or t1.diagnosis_label regexp 'signal_alpha|signal_beta|signal_gamma')
      and t1.diagnosis_time between '2026-01-01' and '2026-05-26'
      and (t1.primary_flag = 'Y' or t1.diagnosis_sort_no = '1')
),
cte2 as (
    select cte1.*, order_item_label, apply_time
    from synthetic_load_src.order_detail as t1
    left outer join synthetic_load_src.visit_record as t2 on t1.visit_id = t2.visit_id and t1.org_id = t2.org_id
    left outer join cte1 on cte1.person_token = t2.person_token
    where t1.order_item_label regexp 'agent_class_a|agent_class_b'
),
cte3 as (
    select cte2.*, cte2.apply_time as index_date, date_add(day, -30, cte2.apply_time) as index_date_30, date_add(day, -60, cte2.apply_time) as index_date_60, row_number() over (partition by cte2.person_token order by cte2.apply_time) as rn
    from cte2
),
cte4 as (
    select * from cte3 where rn = '1'
),
cte5 as (
    select cte4.*, vr.visit_id as c5_visit_id, vr.org_id as c5_org_id, vr.patient_token as c5_patient_token, vr.visit_time
    from cte4
    left outer join synthetic_load_src.visit_record as vr on cte4.person_token = vr.person_token
),
cte6 as (
    select cte5.*, t1.exam_time, t1.exam_item_name, t1.exam_detail_item_name, t1.result_value, t1.reference_range as index_date_60
    from cte5
    inner join synthetic_load_src.exam_report_detail as t1 on t1.patient_token = cte5.c5_patient_token
    where t1.exam_item_name regexp 'panel_alpha|panel_beta|panel_gamma'
      and t1.exam_time <= cte5.index_date
      and t1.exam_time > cte5.index_date_60
)
select count(_1) from (select person_token from cte6 where person_token is not null group by person_token) as _distinct_group_by_subquery(_1)
) as tlimit limit 0, 1000
