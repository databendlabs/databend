statement ok
insert into synthetic_load_orig.entity_basic_info (
    rid, org_name, org_id, upload_time, source_code, source_name, business_id, person_token, visit_id, event_time,
    status_code, status_name, type_code, type_name, channel_code, channel_name, method_code, method_name,
    amount, quantity, detail_update_time, default_idu, default_pk, default_batch, default_md5
)
select
    blake3(concat(coalesce(org_id, ''), '|', coalesce(source_code, ''), '|', coalesce(business_id, ''))) as rid,
    t.org_name, t.org_id, t.upload_time, t.source_code, t.source_name, t.business_id, t.person_token, t.visit_id, t.event_time,
    case when coalesce(ds_status.dic_cnt, 0) = 0 then t.status_code when d_status.dic_val_code = 'stdnull' then null when d_status.dic_val_code is not null then d_status.dic_val_code when d_status.dic_val_code is null and trim(t.status_name) is null then null else t.status_code end as status_code,
    case when coalesce(ds_status.dic_cnt, 0) = 0 then t.status_name when d_status.dic_val_name = 'stdnull' then null when d_status.dic_val_name is not null then d_status.dic_val_name when d_status.dic_val_name is null and trim(t.status_name) is null then null else t.status_name end as status_name,
    case when coalesce(ds_type.dic_cnt, 0) = 0 then t.type_code when d_type.dic_val_code = 'stdnull' then null when d_type.dic_val_code is not null then d_type.dic_val_code when d_type.dic_val_code is null and trim(t.type_name) is null then null else t.type_code end as type_code,
    case when coalesce(ds_type.dic_cnt, 0) = 0 then t.type_name when d_type.dic_val_name = 'stdnull' then null when d_type.dic_val_name is not null then d_type.dic_val_name when d_type.dic_val_name is null and trim(t.type_name) is null then null else t.type_name end as type_name,
    case when coalesce(ds_channel.dic_cnt, 0) = 0 then t.channel_code when d_channel.dic_val_code = 'stdnull' then null when d_channel.dic_val_code is not null then d_channel.dic_val_code when d_channel.dic_val_code is null and trim(t.channel_name) is null then null else t.channel_code end as channel_code,
    case when coalesce(ds_channel.dic_cnt, 0) = 0 then t.channel_name when d_channel.dic_val_name = 'stdnull' then null when d_channel.dic_val_name is not null then d_channel.dic_val_name when d_channel.dic_val_name is null and trim(t.channel_name) is null then null else t.channel_name end as channel_name,
    case when coalesce(ds_method.dic_cnt, 0) = 0 then t.method_code when d_method.dic_val_code = 'stdnull' then null when d_method.dic_val_code is not null then d_method.dic_val_code when d_method.dic_val_code is null and trim(t.method_name) is null then null else t.method_code end as method_code,
    case when coalesce(ds_method.dic_cnt, 0) = 0 then t.method_name when d_method.dic_val_name = 'stdnull' then null when d_method.dic_val_name is not null then d_method.dic_val_name when d_method.dic_val_name is null and trim(t.method_name) is null then null else t.method_name end as method_name,
    t.amount, t.quantity, t.detail_update_time, 'insert', concat(t.org_id, '|', t.business_id), t.default_batch, blake3(concat(t.business_id, '|', t.default_batch))
from synthetic_load_stage.basic_landing as t
left join synthetic_load_stage.dict_summary as ds_status on ds_status.dic_domain = 'status' and ds_status.raw_name = t.status_name
left join synthetic_load_stage.dict_value as d_status on d_status.dic_domain = 'status' and d_status.raw_name = t.status_name
left join synthetic_load_stage.dict_summary as ds_type on ds_type.dic_domain = 'type' and ds_type.raw_name = t.type_name
left join synthetic_load_stage.dict_value as d_type on d_type.dic_domain = 'type' and d_type.raw_name = t.type_name
left join synthetic_load_stage.dict_summary as ds_channel on ds_channel.dic_domain = 'channel' and ds_channel.raw_name = t.channel_name
left join synthetic_load_stage.dict_value as d_channel on d_channel.dic_domain = 'channel' and d_channel.raw_name = t.channel_name
left join synthetic_load_stage.dict_summary as ds_method on ds_method.dic_domain = 'method' and ds_method.raw_name = t.method_name
left join synthetic_load_stage.dict_value as d_method on d_method.dic_domain = 'method' and d_method.raw_name = t.method_name

