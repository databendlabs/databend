    birth_day date,
    person_token string,
    biz_time timestamp,
    contact_token string,
    gender_code string,
    display_name string,
    id_type_code string,
    default_pk string,
    default_idu string,
    default_batch string,
    default_md5 string,
    detail_update_time timestamp,
    default_update_time timestamp,
    default_create_time timestamp
)

statement ok
insert into synthetic_load_orig.enroll_info
select
    to_date('1990-01-01') + number % 1000,
    concat('person_', to_string(number)),
    to_timestamp('2026-05-01 00:00:00') + number,
    concat('contact_', to_string(number)),
    if(number % 2 = 0, 'G0', 'G1'),
    concat('name_', to_string(number)),
    'ID',
    concat('pk_', to_string(number)),
    'insert',
    'batch_seed',
    blake3(concat('seed_', to_string(number))),
    to_timestamp('2026-05-01 00:00:00') + number,
    to_timestamp('2026-05-01 00:00:00') + number,
    to_timestamp('2026-05-01 00:00:00') + number
from numbers(16)

statement ok
create or replace stage synthetic_load_delta_stage_6 file_format = (type = parquet)

statement ok
remove @synthetic_load_delta_stage_6/enroll_delta

statement ok
copy into @synthetic_load_delta_stage_6/enroll_delta
from (
    select
        to_date('1991-01-01') + number % 1000 as birth_day,
        concat('person_', to_string(number)) as person_token,
        to_timestamp('2026-05-29 00:00:00') + number as biz_time,
        concat('contact_delta_', to_string(number)) as contact_token,
        if(number % 2 = 0, 'G0', 'G1') as gender_code,
        concat('name_delta_', to_string(number)) as display_name,
        'ID' as id_type_code,
        concat('pk_', to_string(number)) as default_pk,
        'upsert' as default_idu,
        'batch_delta' as default_batch,
        blake3(concat('delta_', to_string(number))) as default_md5,
        to_timestamp('2026-05-29 00:00:00') + number as detail_update_time,
        to_timestamp('2026-05-29 00:00:00') + number as default_update_time,
        to_timestamp('2026-05-29 00:00:00') + number as default_create_time
    from numbers(24)
)
file_format = (type = parquet)

statement ok
merge into synthetic_load_orig.enroll_info as target_table
using (
    select * from '@synthetic_load_delta_stage_6/enroll_delta/' (
        file_format => 'parquet',
        pattern => '.*[.]parquet'
    )
) as source_table(
    birth_day, person_token, biz_time, contact_token, gender_code, display_name, id_type_code,
    default_pk, default_idu, default_batch, default_md5, detail_update_time, default_update_time, default_create_time
)
on target_table.default_pk = source_table.default_pk
when matched then update set
    target_table.birth_day = source_table.birth_day,
    target_table.person_token = source_table.person_token,
    target_table.biz_time = source_table.biz_time,
    target_table.contact_token = source_table.contact_token,
    target_table.gender_code = source_table.gender_code,
    target_table.display_name = source_table.display_name,
    target_table.id_type_code = source_table.id_type_code,
    target_table.default_idu = 'update',
    target_table.default_batch = source_table.default_batch,
    target_table.default_md5 = source_table.default_md5,
    target_table.detail_update_time = source_table.detail_update_time,
    target_table.default_update_time = source_table.default_update_time
when not matched then insert (
    birth_day, person_token, biz_time, contact_token, gender_code, display_name, id_type_code,
    default_pk, default_idu, default_batch, default_md5, detail_update_time, default_update_time, default_create_time
) values (
    source_table.birth_day, source_table.person_token, source_table.biz_time, source_table.contact_token,
    source_table.gender_code, source_table.display_name, source_table.id_type_code, source_table.default_pk,
    source_table.default_idu, source_table.default_batch, source_table.default_md5,
    source_table.detail_update_time, source_table.default_update_time, source_table.default_create_time
)

