create or replace table synthetic_load_orig.wide_entity_template (
    rid string,
    org_name string,
    org_id string,
    upload_time timestamp,
    source_code string,
    source_name string,
    business_id string,
    person_token string,
    visit_id string,
    event_time timestamp,
    status_code nullable(string),
    status_name nullable(string),
    type_code nullable(string),
    type_name nullable(string),
    channel_code nullable(string),
    channel_name nullable(string),
    method_code nullable(string),
    method_name nullable(string),
    amount uint64,
    quantity uint64,
    detail_update_time timestamp,
    default_idu string,
    default_pk string,
    default_batch string,
    default_md5 string
)

