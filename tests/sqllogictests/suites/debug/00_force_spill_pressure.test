# Heavy forced-spill workload for the parallel debug suite.
# The 00_ prefix keeps this file in the first parallel batch for --run_dir debug.

statement ok
set max_threads = 8

statement ok
set force_join_data_spill = 1

statement ok
set force_sort_data_spill = 1

statement ok
set force_window_data_spill = 1

statement ok
set force_aggregate_data_spill = 1

statement ok
set join_spilling_buffer_threshold_per_proc_mb = 1

statement ok
set sort_spilling_batch_bytes = 1048576

statement ok
set window_spill_unit_size_mb = 1

query I
with joined as (
    select l.number as n
    from numbers_mt(2000000) as l
    inner join numbers_mt(2000000) as r on l.number = r.number
)
select count()
from (
    select n % 1000000 as k, count() as c
    from joined
    group by k
    order by to_string(k) desc
    limit 1000000
)
----
1000000

query I
select count()
from (
    select number
    from numbers_mt(4000000)
    order by to_string(number) desc
    limit 1000000 offset 1000000
)
----
1000000

query I
select max(rn)
from (
    select row_number() over (
        partition by number % 8
        order by to_string(number) desc
    ) as rn
    from numbers_mt(4000000)
)
----
500000

query I
with joined as (
    select l.number as n
    from numbers_mt(2000000) as l
    inner join numbers_mt(2000000) as r on l.number = r.number
    where l.number < 1000000
)
select count()
from (
    select n % 500000 as k, count() as c
    from joined
    group by k
    order by c desc, k desc
    limit 500000
)
----
500000

query I
select max(rn)
from (
    select row_number() over (
        partition by number % 16
        order by to_string(number) desc
    ) as rn
    from numbers_mt(4000000)
)
----
250000

query I
select count()
from (
    select number % 1000000 as k, count() as c
    from numbers_mt(4000000)
    group by k
    order by to_string(k) desc
    limit 1000000
)
----
1000000

query I
with joined as (
    select l.number as n
    from numbers_mt(2000000) as l
    inner join numbers_mt(2000000) as r on l.number = r.number
)
select count()
from (
    select n % 1000000 as k, count() as c
    from joined
    group by k
    order by to_string(k) desc
    limit 1000000
)
----
1000000

statement ok
unset window_spill_unit_size_mb

statement ok
unset sort_spilling_batch_bytes

statement ok
set join_spilling_buffer_threshold_per_proc_mb = 512

statement ok
unset force_aggregate_data_spill

statement ok
unset force_window_data_spill

statement ok
unset force_sort_data_spill

statement ok
unset force_join_data_spill

statement ok
unset max_threads
