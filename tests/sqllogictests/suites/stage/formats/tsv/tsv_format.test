statement ok
drop table if exists tsv_crlf_unterminated_data_cr_repro

statement ok
create table tsv_crlf_trim_repro(a string not null, b string not null)

query TIITI
copy into tsv_crlf_trim_repro from @data/tsv/crlf_record_delimiter.tsv file_format = (type = TEXT record_delimiter = '\r\n')
----
tsv/crlf_record_delimiter.tsv 1 0 NULL NULL

# regression for TEXT CRLF record delimiter: the trailing CR should be trimmed
query TT
select hex(a), hex(b) from tsv_crlf_trim_repro
----
61 62

statement ok
drop table if exists tsv_crlf_trim_repro

statement ok
create table tsv_crlf_empty_line_repro(a string null)

query TIITI
copy into tsv_crlf_empty_line_repro from @data/tsv/crlf_empty_line.tsv file_format = (type = TEXT record_delimiter = '\r\n')
----
tsv/crlf_empty_line.tsv 0 0 NULL NULL

# regression for empty CRLF lines: they should trim to empty rows and be skipped
query I
select count() from tsv_crlf_empty_line_repro
----
0

statement ok
drop table if exists tsv_crlf_empty_line_repro

statement ok
create table tsv_crlf_unterminated_data_cr_repro(a string not null, b string not null)

query TIITI
copy into tsv_crlf_unterminated_data_cr_repro from @data/tsv/crlf_unterminated_data_cr.tsv file_format = (type = TEXT record_delimiter = '\r\n')
----
tsv/crlf_unterminated_data_cr.tsv 1 0 NULL NULL

# regression for unterminated CRLF rows: a trailing data CR must be preserved
query TT
select hex(a), hex(b) from tsv_crlf_unterminated_data_cr_repro
----
61 620d

statement ok
drop table if exists tsv_crlf_unterminated_data_cr_repro
