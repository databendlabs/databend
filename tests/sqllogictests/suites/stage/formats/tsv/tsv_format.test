
query TT
select $1, $2 from @data/tsv/escape.tsv (file_format => 'text')
----
"a 1
"a" 2
"a 3
'a 4
'a' 5
'a 6
'a"b' 7
\ 8
\i 9
'a" b' 10


query TT
select hex($1), hex($2) from @data/tsv/whitespace.tsv (file_format => 'text')
----
3120 3220
2033 2034
203520 3620

query TT
select $1, $2 from @data/tsv/no_newline.tsv (file_format => 'text') a order by $1
----
1 2
3 4


statement ok
drop table if exists tsv_crlf_trim_repro

statement ok
