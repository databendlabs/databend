# No nested types.
# POLICY NO FETCH
query T
select id from @data/parquet/ (files => ('alltypes_plain.parquet')) ;
----
4
5
6
7
2
3
0
1

# POLICY PREDICATE ONLY

# predicate does not contain output
query T
select tinyint_col from @data/parquet/alltypes_plain.parquet ( pattern => '') where id > 3 and bool_col = true;
----
0
0

# predicate contains output
query TT
select tinyint_col, id from @data/parquet/alltypes_plain.parquet ( pattern => '') where id > 3 and bool_col = true;
----
0 4
0 6

# POLICY TOPK ONLY

# topk does not contain output
query T
select `DayOfWeek` from @data/ontime_200.parquet order by `FlightDate` desc limit 3;
----
4
4
4

# topk contains output
query TT
select `FlightDate`, `DayOfWeek` from @data/ontime_200.parquet order by `FlightDate` desc limit 3;
----
2020-12-31 4
2020-12-31 4
2020-12-31 4

# POLICY PREDICATE AND TOPK

# predicate contains topk, but not output
query T
select `DayOfWeek` from @data/ontime_200.parquet where `DayofMonth` > 4 and `FlightDate` > '2020-11-30' order by `FlightDate` desc limit 3;
----
4
4
4

# predicate contains topk and output
query TT
select `DayOfWeek`, `DayofMonth` from @data/ontime_200.parquet where `DayofMonth` > 4 and `FlightDate` > '2020-11-30' order by `FlightDate` desc limit 3;
----
4 31
4 31
4 31

# predicate contains output, but not topk
query TT
select `DayOfWeek`, `DayofMonth` from @data/ontime_200.parquet where `DayofMonth` > 4 order by `FlightDate` desc limit 3;
----
4 31
4 31
4 31

# predicate does not contain topk and output
query T
select `DayOfWeek` from @data/ontime_200.parquet where `DayofMonth` > 4 order by `FlightDate` desc limit 3;
----
4
4
4

# Has nested types.

# POLICY NO FETCH
query TT
select t.1, id from @data/parquet/tuple.parquet;
----
1 1
3 2
3 3

# POLICY PREDICATE ONLY

# predicate does not contain output
query T
select id from @data/parquet/tuple.parquet where t.1 > 1;
----
2
3

query T
select t.1 from @data/parquet/tuple.parquet where id > 1;
----
3
3

# predicate contains output
query TT
select id, t.1 from @data/parquet/tuple.parquet where id > 1;
----
2 3
3 3

query TT
select id, t.1 from @data/parquet/tuple.parquet where t.1 > 1;
----
2 3
3 3

# POLICY TOPK ONLY

# topk does not contain output
query TT
select id, t.2 from @data/parquet/tuple.parquet order by t.1 desc limit 2;
----
3 c
2 b

query TT
select t, t.1 from @data/parquet/tuple.parquet order by id desc limit 2;
----
(3,'c') 3
(3,'b') 3

# topk contains output
query TT
select id, t.2, t.1 from @data/parquet/tuple.parquet order by t.1 desc limit 2;
----
3 c 3
2 b 3

query TT
select id, t.2, t.1, t from @data/parquet/tuple.parquet order by id desc limit 2;
----
3 c 3 (3,'c')
2 b 3 (3,'b')

# POLICY PREDICATE AND TOPK

# predicate contains topk, but not output
query TT
select t.2, t.1 from @data/parquet/tuple.parquet where id > 1 order by id desc limit 1;
----
c 3

# predicate contains topk and output
query TT
select t.2, t.1 from @data/parquet/tuple.parquet where id > 1 and t.1 > 2 order by id desc limit 1;
----
c 3

query TT
select t from @data/parquet/tuple.parquet where id > 1 and t.1 > 2 order by id desc limit 1;
----
(3,'c')

# predicate contains output, but not topk
query TT
select t.2, t.1 from @data/parquet/tuple.parquet where t.1 > 2 order by id desc limit 1;
----
c 3

# predicate does not contain topk and output
query TT
select t.2 from @data/parquet/tuple.parquet where t.1 > 2 order by id desc limit 1;
----
c
