set enable_cse_optimizer=1;

statement ok
create or replace table cse_t as
select number as a, number % 3 as b, number + 100 as c
from numbers(6);

query T nosort
explain select t.a, t.b, agg.max_a
from cse_t t
join (select b, max(a) as max_a from cse_t group by b) agg
on t.b = agg.b;
