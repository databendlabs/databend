# Same-side column scenario: both geometry arguments come from the left table.
# The planner must reject this as a spatial join candidate. Since the predicate
# only references `dual_geom`, it can be pushed into that table scan and the
# remaining join is a regular cross HashJoin.
statement ok
CREATE TABLE dual_geom(id INT, geom1 GEOMETRY, geom2 GEOMETRY)

statement ok
INSERT INTO dual_geom VALUES
(1, TO_GEOMETRY('POLYGON((0 0, 0 5, 5 5, 5 0, 0 0))'), TO_GEOMETRY('POLYGON((1 1, 1 2, 2 2, 2 1, 1 1))'))

query T
EXPLAIN SELECT d.id, r.id
FROM dual_geom AS d
JOIN right_polygons AS r
ON ST_Intersects(d.geom1, d.geom2)
----
