statement ok
CREATE TABLE left_polygons(id INT, geom GEOMETRY)

statement ok
CREATE TABLE right_polygons(id INT, geom GEOMETRY)

statement ok
INSERT INTO left_polygons VALUES
(1, TO_GEOMETRY('POLYGON((0 0, 0 5, 5 5, 5 0, 0 0))')),
(2, TO_GEOMETRY('POLYGON((10 0, 10 5, 15 5, 15 0, 10 0))'))

statement ok
INSERT INTO right_polygons VALUES
(10, TO_GEOMETRY('POLYGON((1 1, 1 2, 2 2, 2 1, 1 1))')),
(20, TO_GEOMETRY('POLYGON((11 1, 11 2, 12 2, 12 1, 11 1))')),
(30, TO_GEOMETRY('POLYGON((100 100, 100 101, 101 101, 101 100, 100 100))'))

statement ok
SET enable_spatial_join = 0

query T
EXPLAIN SELECT l.id, r.id
FROM left_polygons AS l
JOIN right_polygons AS r
ON ST_Intersects(l.geom, r.geom)
