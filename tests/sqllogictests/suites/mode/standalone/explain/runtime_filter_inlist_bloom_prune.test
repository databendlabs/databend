statement ok
create or replace table test_a(number UInt64 not null) row_per_block = 1000 as
select if(number < 10, number + 50000, number + 1000000) as number from numbers(10000);

statement ok
create or replace table test_b(number UInt64 not null) bloom_index_columns='number' row_per_block = 1000 as
select (number % 1000) * 100 + (number DIV 1000) as number from numbers(100000);

query I
select count() from test_b where number in (select number from test_a limit 10);
----
10

