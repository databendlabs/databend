statement ok
USE db_skew_join

statement ok
SET max_threads = 8

statement ok
SET enable_analyze_histogram = 0

statement ok
SET enable_table_snapshot_stats = 1

statement ok
SET enforce_shuffle_join = 1

statement ok
SET enable_experimental_skew_join = 1

statement ok
SET optimizer_skip_list = ''

statement ok
CREATE TABLE skew_probe(k int not null) approx_distinct_columns = '' analyze_top_n_columns = 'k' analyze_top_n_size = 2

statement ok
CREATE TABLE skew_build(k int not null) approx_distinct_columns = '' analyze_top_n_columns = 'k' analyze_top_n_size = 2

statement ok
INSERT INTO skew_probe
SELECT if(number < 990000, 1, number - 989998)::int FROM numbers(1000000)

statement ok
INSERT INTO skew_build
SELECT if(number < 2, 1, number)::int FROM numbers(3)

statement ok
ANALYZE TABLE skew_probe

statement ok
