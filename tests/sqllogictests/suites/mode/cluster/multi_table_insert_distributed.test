EXPLAIN INSERT ALL
  WHEN true THEN INTO mti_all
  WHEN b = 0 THEN INTO mti_mod0 VALUES(a, 'mod0')
  WHEN a % 2 = 0 THEN INTO mti_even VALUES(a, 'even')
