statement ok
drop database if exists mti_distributed

statement ok
create database mti_distributed

statement ok
use mti_distributed

statement ok
create table mti_src(a int, b int)

statement ok
insert into mti_src select number::int, (number % 3)::int from numbers(100)

statement ok
create table mti_all(a int, b int)

statement ok
create table mti_even(a int, tag string)

statement ok
create table mti_mod0(a int, tag string)

query III
INSERT ALL
  WHEN true THEN INTO mti_all
  WHEN b = 0 THEN INTO mti_mod0 VALUES(a, 'mod0')
  WHEN a % 2 = 0 THEN INTO mti_even VALUES(a, 'even')
SELECT * FROM mti_src
----
100 50 34

query IIII
select count(*), sum(a), min(b), max(b) from mti_all
----
100 4950 0 2

query IIII
select count(*), sum(a), min(a), max(a) from mti_even
----
50 2450 0 98

query IIII
select count(*), sum(a), min(a), max(a) from mti_mod0
----
34 1683 0 99

