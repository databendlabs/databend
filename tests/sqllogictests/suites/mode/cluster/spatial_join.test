statement ok
DROP DATABASE IF EXISTS test_cluster_spatial_join

statement ok
CREATE DATABASE test_cluster_spatial_join

statement ok
USE test_cluster_spatial_join

statement ok
CREATE TABLE small_polygons(id INT, geom GEOMETRY)

statement ok
CREATE TABLE large_polygons(id INT, geom GEOMETRY)

statement ok
INSERT INTO small_polygons VALUES
(1, TO_GEOMETRY('POLYGON((0 0, 0 5, 5 5, 5 0, 0 0))')),
(2, TO_GEOMETRY('POLYGON((10 0, 10 5, 15 5, 15 0, 10 0))'))

statement ok
INSERT INTO large_polygons SELECT number, TO_GEOMETRY('POLYGON((1 1, 1 2, 2 2, 2 1, 1 1))') FROM numbers(300)

statement ok
SET enable_spatial_join = 1

# The small input sits in the left/probe position. In a cluster the cost model
# must broadcast the smaller side, so the join materializes as a
# BroadcastSpatialJoin that broadcasts `small_polygons` instead of silently
# falling back to HashJoin. This is the left-build case that previously
# regressed because the build side was chosen twice with inconsistent inputs.
query T
EXPLAIN SELECT s.id, l.id
FROM small_polygons AS s
JOIN large_polygons AS l
ON ST_Intersects(s.geom, l.geom)
----
Exchange
├── output columns: [l.id (#2), s.id (#0)]
├── exchange type: Merge
└── BroadcastSpatialJoin
    ├── output columns: [l.id (#2), s.id (#0)]
    ├── build side: Right
    ├── spatial predicates: [st_intersects(s.geom (#1), l.geom (#3))]
    ├── Exchange(Build)
    │   ├── output columns: [s.id (#0), s.geom (#1)]
    │   ├── exchange type: Broadcast
    │   └── TableScan
    │       ├── table: default.test_cluster_spatial_join.small_polygons
    │       ├── scan id: 0
    │       ├── output columns: [id (#0), geom (#1)]
    │       ├── read rows: 2
    │       ├── read size: <slt:ignore>
    │       ├── partitions total: 1
    │       ├── partitions scanned: 1
    │       ├── pruning stats: [segments: <read cost: <slt:ignore>, decompress cost: <slt:ignore>, range pruning: 1 to 1 cost: <slt:ignore>>, blocks: <range pruning: 1 to 1 cost: <slt:ignore>>]
    │       ├── push downs: [filters: [], limit: NONE]
    │       └── estimated rows: 2.00
    └── TableScan(Probe)
        ├── table: default.test_cluster_spatial_join.large_polygons
        ├── scan id: 1
        ├── output columns: [id (#2), geom (#3)]
        ├── read rows: 300
        ├── read size: <slt:ignore>
        ├── partitions total: <slt:ignore>
        ├── partitions scanned: <slt:ignore>
        ├── pruning stats: <slt:ignore>
        ├── push downs: [filters: [], limit: NONE]
        └── estimated rows: 300.00

# Same query must return identical rows whether or not the spatial path is used.
query I
SELECT count(*)
FROM small_polygons AS s
JOIN large_polygons AS l
ON ST_Intersects(s.geom, l.geom)
----
300

# Q8-style distance predicates should take the same distributed spatial path.
query T
EXPLAIN SELECT s.id, l.id
FROM small_polygons AS s
JOIN large_polygons AS l
ON ST_DWithin(s.geom, l.geom, 0.5)
----
Exchange
├── output columns: [l.id (#2), s.id (#0)]
├── exchange type: Merge
└── BroadcastSpatialJoin
    ├── output columns: [l.id (#2), s.id (#0)]
    ├── build side: Right
    ├── spatial predicates: [st_dwithin(s.geom (#1), l.geom (#3), 0.5)]
    ├── Exchange(Build)
    │   ├── output columns: [s.id (#0), s.geom (#1)]
    │   ├── exchange type: Broadcast
    │   └── TableScan
    │       ├── table: default.test_cluster_spatial_join.small_polygons
    │       ├── scan id: 0
    │       ├── output columns: [id (#0), geom (#1)]
    │       ├── read rows: 2
    │       ├── read size: <slt:ignore>
    │       ├── partitions total: 1
    │       ├── partitions scanned: 1
    │       ├── pruning stats: [segments: <read cost: <slt:ignore>, decompress cost: <slt:ignore>, range pruning: 1 to 1 cost: <slt:ignore>>, blocks: <range pruning: 1 to 1 cost: <slt:ignore>>]
    │       ├── push downs: [filters: [], limit: NONE]
    │       └── estimated rows: 2.00
    └── TableScan(Probe)
        ├── table: default.test_cluster_spatial_join.large_polygons
        ├── scan id: 1
        ├── output columns: [id (#2), geom (#3)]
        ├── read rows: 300
        ├── read size: <slt:ignore>
        ├── partitions total: <slt:ignore>
        ├── partitions scanned: <slt:ignore>
        ├── pruning stats: <slt:ignore>
        ├── push downs: [filters: [], limit: NONE]
        └── estimated rows: 300.00

query I
SELECT count(*)
FROM small_polygons AS s
JOIN large_polygons AS l
ON ST_DWithin(s.geom, l.geom, 0.5)
----
300

