statement ok
set enable_experimental_table_ref=1;

statement ok
DROP DATABASE IF EXISTS test_branch_optimize

statement ok
CREATE DATABASE test_branch_optimize

statement ok
USE test_branch_optimize

statement ok
CREATE OR REPLACE TABLE t1(a INT) row_per_block=1

statement ok
INSERT INTO t1 VALUES (1), (2)

statement ok
ALTER TABLE t1 CREATE BRANCH dev

statement ok
INSERT INTO t1/dev VALUES (3), (4)

statement ok
OPTIMIZE TABLE t1/dev COMPACT

statement ok
OPTIMIZE TABLE t1/dev COMPACT SEGMENT

statement ok
OPTIMIZE TABLE t1/dev ALL

statement ok
ANALYZE TABLE t1/dev NOSCAN

query TTTIIIITTIT
SHOW STATISTICS FROM TABLE t1/dev
----
test_branch_optimize t1/dev a 4 4 4 0 1 4 5 (empty)

statement error OPTIMIZE TABLE ... PURGE is not supported on table branch
OPTIMIZE TABLE t1/dev PURGE

query I
SELECT count() FROM t1/dev
----
4

query I
SELECT count() FROM t1
----
2

#######################################
# branch-specific Hilbert recluster   #
#######################################

statement ok
set hilbert_clustering_min_bytes = 35;

statement ok
CREATE OR REPLACE TABLE t_hilbert(a INT, b INT) CLUSTER BY HILBERT(a, b) row_per_block=2 block_per_segment=2 block_size_threshold = 18

statement ok
ALTER TABLE t_hilbert CREATE BRANCH dev

statement ok
ALTER TABLE t_hilbert/dev ADD COLUMN c INT

statement ok
ALTER TABLE t_hilbert/dev CLUSTER BY HILBERT(a, c)

statement ok
INSERT INTO t_hilbert/dev(a, b, c) VALUES(1, 1, 1), (3, 3, 3)

statement ok
INSERT INTO t_hilbert/dev(a, b, c) VALUES(0, 0, 0), (5, 5, 5)

statement ok
INSERT INTO t_hilbert/dev(a, b, c) VALUES(2, 2, 2), (6, 6, 6)

statement ok
INSERT INTO t_hilbert/dev(a, b, c) VALUES(4, 4, 4), (7, 7, 7)

statement ok
ALTER TABLE t_hilbert/dev RECLUSTER FINAL

query III
SELECT count(), sum(a), sum(c) FROM t_hilbert/dev
----
8 28 28

query TT
SELECT cluster_key, type FROM clustering_information('test_branch_optimize','t_hilbert/dev')
----
(a, c) hilbert
