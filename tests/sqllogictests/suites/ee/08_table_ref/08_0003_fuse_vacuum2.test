statement ok
set enable_experimental_table_ref=1;

statement ok
DROP DATABASE IF EXISTS test_vacuum2_table_ref

statement ok
CREATE DATABASE test_vacuum2_table_ref

statement ok
USE test_vacuum2_table_ref

## -------------------------------------------------------
## Undrop branch cases must run before fuse_vacuum2 updates
## the tenant-level vacuum watermark.
## -------------------------------------------------------

statement ok
CREATE OR REPLACE TABLE t_undrop(a INT, b STRING)

statement ok
INSERT INTO t_undrop VALUES (1, 'a'), (2, 'b'), (3, 'c')

statement ok
ALTER TABLE t_undrop CREATE BRANCH dev

statement ok
ALTER TABLE t_undrop DROP BRANCH dev

statement error 2745
SELECT * FROM t_undrop/dev

statement ok
ALTER TABLE t_undrop UNDROP BRANCH dev

query IT
SELECT * FROM t_undrop/dev ORDER BY a
----
1 a
2 b
3 c

statement ok
ALTER TABLE t_undrop DROP BRANCH dev

statement ok
ALTER TABLE t_undrop UNDROP BRANCH dev RETAIN 1 SECONDS

statement ok
SELECT SLEEP(1)

statement error 2748
SELECT * FROM t_undrop/dev

statement ok
ALTER TABLE t_undrop DROP BRANCH dev

query TB
SELECT name, dropped_on IS NOT NULL FROM system.branches_with_history WHERE database = 'test_vacuum2_table_ref' AND table = 't_undrop' AND name = 'dev'
----
dev 1

statement ok
ALTER TABLE t_undrop UNDROP BRANCH dev RETAIN 7 DAYS

query TB
SELECT name, expire_at IS NOT NULL FROM system.branches WHERE database = 'test_vacuum2_table_ref' AND table = 't_undrop' AND name = 'dev'
----
dev 1

query IT
SELECT * FROM t_undrop/dev ORDER BY a
----
1 a
2 b
3 c

statement ok
set data_retention_time_in_days = 0;

## -------------------------------------------------------
## Expired tag metadata is purged by fuse_vacuum2.
## -------------------------------------------------------

statement ok
CREATE OR REPLACE TABLE t_tag_gc(a INT, b STRING)

statement ok
INSERT INTO t_tag_gc VALUES (1, 'a'), (2, 'b'), (3, 'c')

statement ok
ALTER TABLE t_tag_gc CREATE TAG v1_0

statement ok
INSERT INTO t_tag_gc VALUES (4, 'd'), (5, 'e')

statement ok
ALTER TABLE t_tag_gc CREATE TAG v1_0_copy AT (TAG => v1_0)

statement ok
ALTER TABLE t_tag_gc CREATE TAG temp_tag RETAIN 2 SECONDS

statement ok
SELECT SLEEP(2)

query TB
select name, expire_at is not null from fuse_tag('test_vacuum2_table_ref','t_tag_gc') order by name
----
temp_tag 1
v1_0 0
v1_0_copy 0

statement ok
optimize table t_tag_gc compact

statement ok
select * from fuse_vacuum2('test_vacuum2_table_ref', 't_tag_gc') ignore_result;

query TB
select name, expire_at is not null from fuse_tag('test_vacuum2_table_ref','t_tag_gc') order by name
----
v1_0 0
v1_0_copy 0

query IT
SELECT * FROM t_tag_gc at (tag => "v1_0") ORDER BY a
----
1 a
2 b
3 c

statement ok
CREATE OR REPLACE TABLE t1(c INT)

statement ok
INSERT INTO t1 VALUES (1), (2)

statement ok
ALTER TABLE t1 CREATE BRANCH b1

statement ok
INSERT INTO t1 VALUES (3)

statement ok
ALTER TABLE t1/b1 CREATE BRANCH b2

statement error
ALTER TABLE t1/b1 CREATE TAG t1

statement error 1002
OPTIMIZE TABLE t1 PURGE

statement error 1002
VACUUM TABLE t1

statement ok
select * from fuse_vacuum2('test_vacuum2_table_ref', 't1') ignore_result;

query I
SELECT c FROM t1/b1 ORDER BY c
----
1
2

query I
SELECT c FROM t1/b2 ORDER BY c
----
1
2

## -------------------------------------------------------
## Case 1:
## b1 owns new branch-only data, b2 is created from b1.
## After dropping b1, vacuum2 must keep b1-owned files alive
## because b2 still references them.
## After dropping b2, the old branch-only files can be reclaimed.
## -------------------------------------------------------

statement ok
CREATE OR REPLACE STAGE stage_branch_chain url = 'fs:///tmp/test_vacuum2_table_ref/branch_chain/';

statement ok
remove @stage_branch_chain;

statement ok
CREATE TABLE t_branch_chain(c INT) 'fs:///tmp/test_vacuum2_table_ref/branch_chain/';

statement ok
INSERT INTO t_branch_chain VALUES (1)

statement ok
ALTER TABLE t_branch_chain CREATE BRANCH b1

statement ok
INSERT INTO t_branch_chain/b1 VALUES (10)

statement ok
ALTER TABLE t_branch_chain/b1 CREATE BRANCH b2

query I
select count() from list_stage(location=> '@stage_branch_chain') where name like '%\/_b\/%';
----
2

statement ok
ALTER TABLE t_branch_chain DROP BRANCH b1

statement ok
SELECT SLEEP(1)

statement ok
select * from fuse_vacuum2('test_vacuum2_table_ref', 't_branch_chain') ignore_result;

query I
SELECT COUNT(*) FROM t_branch_chain
----
1

query I
SELECT COUNT(*) FROM t_branch_chain/b2
----
2

statement ok
ALTER TABLE t_branch_chain DROP BRANCH b2

statement ok
SELECT SLEEP(1)

statement ok
select * from fuse_vacuum2('test_vacuum2_table_ref', 't_branch_chain') ignore_result;

query I
SELECT COUNT(*) FROM t_branch_chain
----
1

query I
select count() from list_stage(location=> '@stage_branch_chain') where name like '%\/_b\/%';
----
1

statement error
SELECT COUNT(*) FROM t_branch_chain/b2

statement ok
remove @stage_branch_chain;

statement ok
drop stage stage_branch_chain;

## -------------------------------------------------------
## Case 2:
## Active tag protects old base-table files even after the base
## table has moved to a newer snapshot.
## -------------------------------------------------------

statement ok
CREATE OR REPLACE STAGE stage_tag_keep url = 'fs:///tmp/test_vacuum2_table_ref/tag_keep/';

statement ok
remove @stage_tag_keep;

statement ok
CREATE TABLE t_tag_keep(c INT) 'fs:///tmp/test_vacuum2_table_ref/tag_keep/';

statement ok
INSERT INTO t_tag_keep VALUES (1)

statement ok
ALTER TABLE t_tag_keep CREATE TAG keep_v1

statement ok
DELETE FROM t_tag_keep WHERE c >= 1

statement ok
INSERT INTO t_tag_keep VALUES (2)

query I
select count() from list_stage(location=> '@stage_tag_keep') where name like '%\/_b\/%';
----
2

statement ok
select * from fuse_vacuum2('test_vacuum2_table_ref', 't_tag_keep') ignore_result;

query I
SELECT COUNT(*) FROM t_tag_keep
----
1

query I
SELECT COUNT(*) FROM t_tag_keep AT (TAG => "keep_v1")
----
1

query I
select count() from list_stage(location=> '@stage_tag_keep') where name like '%\/_b\/%';
----
2

statement ok
ALTER TABLE t_tag_keep DROP TAG keep_v1

statement ok
select * from fuse_vacuum2('test_vacuum2_table_ref', 't_tag_keep') ignore_result;

query I
select count() from list_stage(location=> '@stage_tag_keep') where name like '%\/_b\/%';
----
1

statement ok
remove @stage_tag_keep;

statement ok
drop stage stage_tag_keep;

## -------------------------------------------------------
## Case 3:
## Expired tag no longer protects its historical files after vacuum2.
## -------------------------------------------------------

statement ok
CREATE OR REPLACE STAGE stage_tag_expired url = 'fs:///tmp/test_vacuum2_table_ref/tag_expired/';

statement ok
remove @stage_tag_expired;

statement ok
CREATE TABLE t_tag_expired(c INT) 'fs:///tmp/test_vacuum2_table_ref/tag_expired/';

statement ok
INSERT INTO t_tag_expired VALUES (1)

statement ok
ALTER TABLE t_tag_expired CREATE TAG temp_v1 RETAIN 1 SECONDS

statement ok
DELETE FROM t_tag_expired WHERE c >= 1

statement ok
INSERT INTO t_tag_expired VALUES (2)

query I
select count() from list_stage(location=> '@stage_tag_expired') where name like '%\/_b\/%';
----
2

statement ok
SELECT SLEEP(2)

statement ok
select * from fuse_vacuum2('test_vacuum2_table_ref', 't_tag_expired') ignore_result;

query I
SELECT COUNT(*) FROM t_tag_expired
----
1

query I
select count() from list_stage(location=> '@stage_tag_expired') where name like '%\/_b\/%';
----
1

statement error
SELECT COUNT(*) FROM t_tag_expired AT (TAG => "temp_v1")

statement ok
remove @stage_tag_expired;

statement ok
drop stage stage_tag_expired;

statement ok
DROP DATABASE test_vacuum2_table_ref

## -------------------------------------------------------
## Vacuum2 + virtual column cases.
## -------------------------------------------------------

statement ok
set enable_experimental_table_ref=1;

statement ok
set enable_experimental_virtual_column=1;

statement ok
DROP DATABASE IF EXISTS test_table_ref_virtual_column

statement ok
CREATE DATABASE test_table_ref_virtual_column

statement ok
USE test_table_ref_virtual_column

statement ok
set data_retention_time_in_days = 0;

## -------------------------------------------------------
## Active branch keeps virtual column files referenced only
## by the branch snapshot alive.
## -------------------------------------------------------

statement ok
CREATE OR REPLACE STAGE vc_branch_stage url = 'fs:///tmp/test_table_ref_virtual_column/branch_keep/';

statement ok
remove @vc_branch_stage;

statement ok
CREATE TABLE t_branch_keep (id INT, v VARIANT) 'fs:///tmp/test_table_ref_virtual_column/branch_keep/';

statement ok
ALTER TABLE t_branch_keep SET OPTIONS(row_per_block = 2);

statement ok
INSERT INTO t_branch_keep VALUES
    (1, '{"k":"branch_old"}'),
    (2, '{"k":"branch_old"}');

statement ok
REFRESH VIRTUAL COLUMN FOR t_branch_keep;

query I
select count() from list_stage(location=> '@vc_branch_stage') where name like '%_vb_v2%';
----
1

statement ok
ALTER TABLE t_branch_keep CREATE BRANCH b1

statement ok
DELETE FROM t_branch_keep;

statement ok
INSERT INTO t_branch_keep VALUES
    (10, '{"k":"branch_new"}'),
    (11, '{"k":"branch_new"}');

statement ok
REFRESH VIRTUAL COLUMN FOR t_branch_keep;

query I
select count() from list_stage(location=> '@vc_branch_stage') where name like '%_vb_v2%';
----
2

query I
SELECT COUNT(*) FROM t_branch_keep/b1
----
2

statement ok
select * from fuse_vacuum2('test_table_ref_virtual_column', 't_branch_keep') ignore_result;

query I
VACUUM VIRTUAL COLUMN FROM t_branch_keep;
----
0

query I
select count() from list_stage(location=> '@vc_branch_stage') where name like '%_vb_v2%';
----
2

statement ok
remove @vc_branch_stage;

statement ok
drop stage vc_branch_stage;

## -------------------------------------------------------
## Refreshing virtual columns on a branch writes branch-local
## files and vacuum on the base table must still keep them.
## -------------------------------------------------------

statement ok
CREATE OR REPLACE STAGE vc_branch_refresh_stage url = 'fs:///tmp/test_table_ref_virtual_column/branch_refresh/';

statement ok
remove @vc_branch_refresh_stage;

statement ok
CREATE TABLE t_branch_refresh (id INT, v VARIANT) 'fs:///tmp/test_table_ref_virtual_column/branch_refresh/';

statement ok
ALTER TABLE t_branch_refresh SET OPTIONS(row_per_block = 2);

statement ok
INSERT INTO t_branch_refresh VALUES
    (1, '{"k":"base_old"}'),
    (2, '{"k":"base_old"}');

statement ok
REFRESH VIRTUAL COLUMN FOR t_branch_refresh;

statement ok
ALTER TABLE t_branch_refresh CREATE BRANCH b1

statement ok
INSERT INTO t_branch_refresh/b1 VALUES
    (3, '{"k":"branch_new"}'),
    (4, '{"k":"branch_new"}');

statement ok
REFRESH VIRTUAL COLUMN FOR t_branch_refresh/b1;

query TTTITT
SHOW VIRTUAL COLUMNS FROM t_branch_refresh/b1
----
test_table_ref_virtual_column t_branch_refresh v 3000000000 ['k'] String

query T
SELECT branch FROM system.virtual_columns WHERE database = 'test_table_ref_virtual_column' AND table = 't_branch_refresh' AND branch = 'b1'
----
b1

query I
select count() from list_stage(location=> '@vc_branch_refresh_stage') where name like '%_vb_v2%';
----
2

statement ok
DELETE FROM t_branch_refresh;

statement ok
INSERT INTO t_branch_refresh VALUES
    (10, '{"k":"base_new"}'),
    (11, '{"k":"base_new"}');

statement ok
REFRESH VIRTUAL COLUMN FOR t_branch_refresh;

query I
select count() from list_stage(location=> '@vc_branch_refresh_stage') where name like '%_vb_v2%';
----
3

statement ok
select * from fuse_vacuum2('test_table_ref_virtual_column', 't_branch_refresh') ignore_result;

query I
VACUUM VIRTUAL COLUMN FROM t_branch_refresh;
----
0

query I
select count() from list_stage(location=> '@vc_branch_refresh_stage') where name like '%_vb_v2%';
----
3

statement ok
remove @vc_branch_refresh_stage;

statement ok
drop stage vc_branch_refresh_stage;

