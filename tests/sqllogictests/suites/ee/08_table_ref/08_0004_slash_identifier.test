statement ok
set enable_experimental_table_ref=1

query TT
SELECT name, branch FROM system.columns WHERE database = 'test_table_ref_slash_identifier' AND `table` = 't' AND branch = 'slash' ORDER BY name
----
branch_col slash

query I
SELECT count() FROM system.columns WHERE database = 'test_table_ref_slash_identifier' AND `table` = 't' AND branch != ''
----
1

query I
SELECT count() FROM system.columns WHERE database = 'test_table_ref_slash_identifier' AND `table` = 't' AND branch LIKE 'sla%'
----
1

query I
SELECT count() FROM system.columns WHERE database = 'test_table_ref_slash_identifier' AND `table` = 't' AND branch LIKE '%'
----
2

query TB
SELECT name, ok FROM (
    SELECT 'fuse_block' AS name, count() = 1 AS ok FROM fuse_block('test_table_ref_slash_identifier', '`t/slash`')
    UNION ALL SELECT 'fuse_snapshot', max(row_count) = 1 FROM fuse_snapshot('test_table_ref_slash_identifier', '`t/slash`')
) ORDER BY name
----
fuse_block 1
fuse_snapshot 1

