statement ok
USE test_branch_vacuum

statement ok
set data_retention_time_in_days = 0;

statement ok
CREATE OR REPLACE TABLE t1(c INT)

statement ok
INSERT INTO t1 VALUES (1), (2)

statement ok
ALTER TABLE t1 CREATE BRANCH b1

statement ok
INSERT INTO t1 VALUES (3)

statement ok
ALTER TABLE t1/b1 CREATE BRANCH b2

statement error 2747
ALTER TABLE t1/b1 CREATE TAG t1

statement ok
select * from fuse_vacuum2('test_branch_vacuum', 't1') ignore_result;

query I
SELECT c FROM t1/b1 ORDER BY c
----
