statement ok
set global enable_experimental_row_access_policy = 1;

statement ok
set enable_planner_cache = 0;

statement ok
drop table if exists rap_select_subquery_test;

statement ok
drop table if exists rap_select_subquery_aux;

statement ok
drop row access policy if exists rap_select_subquery_policy;

statement ok
create row access policy rap_select_subquery_policy as (dept string) returns boolean -> dept = 'sales';

statement ok
create table rap_select_subquery_test(id int, dept string, val int);

statement ok
insert into rap_select_subquery_test values
    (1, 'sales', 100),
    (2, 'eng', 200),
    (3, 'sales', 300);

statement ok
create table rap_select_subquery_aux(id int, dept string);

statement ok
insert into rap_select_subquery_aux values
    (2, 'eng'),
    (3, 'sales');

statement ok
alter table rap_select_subquery_test add row access policy rap_select_subquery_policy on (dept);

## Baseline: RAP only exposes policy-visible rows.
query IIT
select id, val, dept from rap_select_subquery_test order by id;
----
1 100 sales
3 300 sales

## Query-side IN should still honor RAP when the protected table is the outer relation.
query I
select id
from rap_select_subquery_test
where id in (select id from rap_select_subquery_aux where dept = 'eng')
order by id;
----

## Query-side IN should still return visible rows when the subquery matches them.
query I
select id
from rap_select_subquery_test
where id in (select id from rap_select_subquery_aux where dept = 'sales')
order by id;
----
3

## Query-side EXISTS should still honor RAP after decorrelation.
query I
select id
from rap_select_subquery_test t
where exists (
    select 1
    from rap_select_subquery_aux a
    where a.id = t.id and a.dept = 'eng'
)
order by id;
----

## EXISTS over a protected subquery should not observe policy-invisible rows.
query T
select exists(
    select 1
    from rap_select_subquery_test
    where dept = 'eng'
);
----
0

## IN over a protected subquery should not observe policy-invisible rows.
query T
select 2 in (select id from rap_select_subquery_test);
----
0

## Correlated EXISTS over the protected table should still see policy-visible rows.
query T
select exists(
    select 1
    from rap_select_subquery_test t
    where t.id = 3 and t.val = 300
);
----
1

statement ok
drop table rap_select_subquery_aux;

statement ok
drop table rap_select_subquery_test;

statement ok
drop row access policy rap_select_subquery_policy;
