## Cross-database: index should work even when session is in a different database.
## CREATE AGGREGATING INDEX requires the session to be in the target database,
## but the persisted query is database-qualified, so validation resolves correctly
## regardless of the caller's current database.

statement ok
CREATE OR REPLACE TABLE t_cross_db(a INT, b INT)

statement ok
CREATE AGGREGATING INDEX idx_cross AS SELECT a, b FROM t_cross_db WHERE b > 1

