## Test: RAP definition cache correctness
## Verifies that the query-node local definition cache does not
## produce stale or incorrect results across attach/detach/re-attach cycles.

statement ok
set global enable_experimental_row_access_policy = 1;

statement ok
set enable_planner_cache = 0;

statement ok
drop table if exists rap_def_cache_t;

statement ok
drop row access policy if exists rap_def_cache_p1;

statement ok
drop row access policy if exists rap_def_cache_p2;

## ========================================
## Setup: table + two different policies
## ========================================

statement ok
create table rap_def_cache_t(id int, dept string);

statement ok
insert into rap_def_cache_t values (1, 'Engineering'), (2, 'Sales'), (3, 'Engineering');

## p1: only Engineering rows visible
statement ok
CREATE ROW ACCESS POLICY rap_def_cache_p1 AS (dept_col STRING) RETURNS BOOLEAN ->
  dept_col = 'Engineering';

## p2: only Sales rows visible
statement ok
CREATE ROW ACCESS POLICY rap_def_cache_p2 AS (dept_col STRING) RETURNS BOOLEAN ->
  dept_col = 'Sales';

## ========================================
## Step 1: Attach p1, query twice (second should hit cache)
## ========================================

statement ok
alter table rap_def_cache_t add row access policy rap_def_cache_p1 on (dept);

query IT
select * from rap_def_cache_t order by id;
----
1 Engineering
3 Engineering

## Second query — exercises cache hit path
query IT
select * from rap_def_cache_t order by id;
----
1 Engineering
3 Engineering

## ========================================
## Step 2: Detach p1, verify no RAP applied
## ========================================

statement ok
alter table rap_def_cache_t drop row access policy rap_def_cache_p1;

query IT
select * from rap_def_cache_t order by id;
----
1 Engineering
2 Sales
3 Engineering

## ========================================
## Step 3: Attach p2 (different policy), verify correct definition used
## ========================================

statement ok
alter table rap_def_cache_t add row access policy rap_def_cache_p2 on (dept);

query IT
select * from rap_def_cache_t order by id;
----
2 Sales

## Second query — cache hit for p2
query IT
select * from rap_def_cache_t order by id;
----
2 Sales

## ========================================
## Step 4: Detach p2, drop both policies, re-query
## ========================================

statement ok
alter table rap_def_cache_t drop row access policy rap_def_cache_p2;

## All rows visible after detach
query IT
select * from rap_def_cache_t order by id;
----
1 Engineering
2 Sales
3 Engineering

## ========================================
## Cleanup
## ========================================

statement ok
drop table rap_def_cache_t;

statement ok
drop row access policy rap_def_cache_p1;

statement ok
drop row access policy rap_def_cache_p2;
