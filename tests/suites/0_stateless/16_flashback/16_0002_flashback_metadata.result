>>>> INSERT INTO db_16_0002.t_bloom VALUES (2, 2, 2)
#### flashback bloom table to saved snapshot
>>>> SELECT table_option NOT LIKE '%BLOOM_INDEX_COLUMNS=%' FROM system.tables WHERE database = 'db_16_0002' AND name = 't_bloom'
true
<<<<
