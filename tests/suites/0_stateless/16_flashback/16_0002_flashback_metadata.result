#### prepare flashback metadata regression environment
>>>> DROP DATABASE IF EXISTS db_16_0002
>>>> CREATE DATABASE db_16_0002
#### flashback should clear bloom index options tied to dropped columns
>>>> CREATE OR REPLACE TABLE db_16_0002.t_bloom(a INT, b INT)
>>>> INSERT INTO db_16_0002.t_bloom VALUES (1, 1)
>>>> ALTER TABLE db_16_0002.t_bloom ADD COLUMN c INT
